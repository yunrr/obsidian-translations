    {
      "type": "title",
      "source": "Enable background wave design on left sidebar",
      "target": "在左侧边栏启用背景波浪设计"
    },
    {
      "type": "title",
      "source": "Enable alternative background color for right sidebar",
      "target": "为右侧边栏启用替代背景色"
    },
    {
      "type": "title",
      "source": "Enable rounded top-left corner of the main pane",
      "target": "为主面板启用左上角圆角"
    },
    {
      "type": "title",
      "source": "Enable sliding animation on main pane",
      "target": "为主面板启用滑动动画"
    },
    {
      "type": "description",
      "source": "Animation is noticable when you switch to a new tab",
      "target": "当您切换到新标签页时，动画效果会很明显。"
    },
    {
      "type": "title",
      "source": "Layout Section",
      "target": "布局部分"
    },
    {
      "type": "title",
      "source": "Enable Overlay Scrollbar",
      "target": "启用覆盖滚动条"
    },
    {
      "type": "description",
      "source": "Overlay will provide you wider field of contents, but in return, scrollbar will have to overlap onto it.",
      "target": "覆盖滚动条将为您提供更宽的内容区域，但作为回报，滚动条将不得不覆盖在内容之上。"
    },
    {
      "type": "title",
      "source": "Enable Easy Toggle",
      "target": "启用简易切换"
    },
    {
      "type": "description",
      "source": "Enabling Easy Toggle gives you more triggerable area to reveal the hidden buttons.",
      "target": "启用简易切换将为您提供更大的可触发区域来显示隐藏的按钮。"
    },
    {
      "type": "title",
      "source": "Enable Alternative Toggle Style (Top-right)",
      "target": "启用替代切换样式（右上角）"
    },
    {
      "type": "description",
      "source": "Enabling this will switch the toggle style from \"sliding\" to \"fading\".",
      "target": "启用此选项将把切换样式从“滑动”切换为“渐隐”。"
