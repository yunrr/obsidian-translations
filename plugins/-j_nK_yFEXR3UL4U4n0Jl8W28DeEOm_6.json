        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "When a recipe is added to the grocery list, write today's date to its frontmatter so you can see the last time you cooked it.",
          "target": "当食谱被添加到购物清单时，将今天的日期写入其前置属性，以便查看上次烹饪时间。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Frontmatter property used to store the last made date.",
          "target": "用于存储上次烹饪日期的前置属性。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Increment the recipe's `cookedCount` frontmatter when it's added to the grocery list on a new day. Powers the cooking stats leaderboard.",
          "target": "当食谱在新的一天被添加到购物清单时，递增其`cookedCount`前置属性。此功能驱动烹饪统计排行榜。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Comma-separated allergens to warn about. Recipes with a matching `allergens` frontmatter entry show a red warning.",
