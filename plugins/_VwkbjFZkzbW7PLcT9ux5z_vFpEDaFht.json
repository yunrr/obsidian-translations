{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "rich-foot",
    "version": "2.0.0",
    "title": "Rich Foot",
    "description": "Adds backlink tags and created/modified dates to the footer of your notes.",
    "language": "zh-cn",
    "supportedVersions": "1.4.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "text: `${modified}`",
          "target": "text: `${modified}`"
        },
        {
          "source": "text: `${created}`",
          "target": "text: `${created}`"
        },
        {
          "source": "text: \"Rich Foot adds a footer to your notes with useful information such as backlinks, creation date, and last modified date.\"",
          "target": "text: \"Rich Foot 为您的笔记添加一个页脚，包含有用的信息，如反向链接、创建日期和最后修改日期。\""
        },
        {
          "source": "text: \"Excluded Folders\"",
          "target": "text: \"排除的文件夹\""
        },
        {
          "source": "text: \"Notes in excluded folders (and their subfolders) will not display the Rich Foot footer. This is useful for system folders or areas where you don't want footer information to appear.\"",
          "target": "text: \"排除文件夹（及其子文件夹）中的笔记将不显示 Rich Foot 页脚。这对于系统文件夹或您不希望显示页脚信息的区域非常有用。\""
        },
        {
          "source": "text: \"Delete\"",
          "target": "text: \"删除\""
        },
        {
          "source": "text: \"Visibility Settings\"",
          "target": "text: \"可见性设置\""
        },
        {
          "source": "text: \"Example Screenshot\"",
          "target": "text: \"示例截图\""
        },
        {
          "source": ".setButtonText(\"Browse\")",
          "target": ".setButtonText(\"浏览\")"
        },
        {
          "source": ".setButtonText(\"Add\")",
          "target": ".setButtonText(\"添加\")"
        },
        {
          "source": ".setName(\"Add excluded folder\")",
          "target": ".setName(\"添加排除的文件夹\")"
        },
        {
          "source": ".setName(\"Show Backlinks\")",
          "target": ".setName(\"显示反向链接\")"
        },
        {
          "source": ".setName(\"Show Outlinks\")",
          "target": ".setName(\"显示外部链接\")"
        },
        {
          "source": ".setName(\"Show Dates\")",
          "target": ".setName(\"显示日期\")"
        },
        {
          "source": ".setDesc(\"Enter a folder path or browse to select\")",
          "target": ".setDesc(\"输入文件夹路径或浏览选择\")"
        },
        {
          "source": ".setDesc(\"Show backlinks in the footer\")",
          "target": ".setDesc(\"在页脚中显示反向链接\")"
        },
        {
          "source": ".setDesc(\"Show outgoing links in the footer\")",
          "target": ".setDesc(\"在页脚中显示外部链接\")"
        },
        {
          "source": ".setDesc(\"Show creation and modification dates in the footer\")",
          "target": ".setDesc(\"在页脚中显示创建和修改日期\")"
        },
        {
          "source": ".setPlaceholder(\"folder/subfolder\")",
          "target": ".setPlaceholder(\"文件夹/子文件夹\")"
        }
      ]
    }
  }
}