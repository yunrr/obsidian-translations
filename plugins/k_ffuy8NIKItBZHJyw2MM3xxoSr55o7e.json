{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "lapel",
    "version": "2.0.0",
    "title": "Lapel",
    "description": "用装饰来装扮你的编辑器，这些装饰可以标记你的每一个标题。",
    "language": "zh-cn",
    "supportedVersions": "0.1.5",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "text:\"Appearance\"",
          "target": "text:\"外观\""
        },
        {
          "source": ".setName(\"Show before line numbers\")",
          "target": ".setName(\"在行号之前显示\")"
        },
        {
          "source": ".setDesc(\"Toggle whether the heading markers are shown before or after the line numbers in the gutter.\")",
          "target": ".setDesc(\"切换标题标记是显示在边距中的行号之前还是之后。.\")"
        },
        {
          "source": ".setTitle(`Heading ${d}`)",
          "target": ".setTitle(`Heading ${d}`)"
        }
      ]
    }
  }
}