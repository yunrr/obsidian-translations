{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-image-layouts",
    "version": "2.0.0",
    "title": "Image Layouts",
    "description": "Add beautiful image layouts to your notes",
    "language": "zh-cn",
    "supportedVersions": "0.15.5",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(f.detail.type)",
          "target": ".log(f.detail.type)"
        },
        {
          "source": ".log(\"unloading plugin\")",
          "target": ".log(\"卸载插件\")"
        },
        {
          "source": "link:\"https://via.placeholder.com/640x480\"",
          "target": "link:\"https://via.placeholder.com/640x480\""
        },
        {
          "source": ".setName(\"Should Overlay Permanently\")",
          "target": ".setName(\"应该永久叠加\")"
        },
        {
          "source": ".setDesc(\"Image overlays don't require hovering\")",
          "target": ".setDesc(\"图像叠加不需要悬停\")"
        }
      ]
    }
  }
}