        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Interactive TikZ Editor: Visual diagram builder with snapping, shape tools, and live preview for faster workflow.",
          "target": "交互式 TikZ 编辑器：可视化图表构建器，具备对齐吸附、形状工具和实时预览功能，可加速工作流程。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Smarter TikZ Rendering: More accurate symbols, better font handling, and consistent diagram output across themes.",
          "target": "更智能的 TikZ 渲染：更精确的符号、更好的字体处理，以及跨主题一致的图表输出。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Enhanced Layout & Responsiveness: Improved diagram alignment, spacing, and adaptive rendering for complex TikZ structures.",
          "target": "增强的布局与响应性：改进了图表对齐、间距，以及针对复杂 TikZ 结构的自适应渲染。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Editing Experience Upgrades: Multi-select editing, lasso selection, and thickness controls for precise diagram customization.",
          "target": "编辑体验升级：多选编辑、套索选择和粗细控制，实现精确的图表自定义。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Rendering Fixes: Resolved symbol mismatches (e.g., Γ, Ω, ⊗) and clipping issues in SVG output.",
          "target": "渲染修复：解决了 SVG 输出中的符号不匹配（例如 Γ, Ω, ⊗）和裁剪问题。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Reliable Package Loading: Fixed missing TikZ libraries to ensure diagrams using advanced packages render correctly.",
          "target": "可靠的包加载：修复了缺失的 TikZ 库，确保使用高级包的图表能正确渲染。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Equation Numbering: Automatic theorem environments and equation referencing.",
          "target": "公式编号：自动定理环境和公式引用。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "LaTeX Autocomplete: Fast suggestions and search for equations/notes in your vault.",
          "target": "LaTeX 自动补全：快速建议和搜索保险库中的公式/笔记。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "PDF Export: Custom print templates (headers, footers) with background graphics support.",
          "target": "PDF 导出：自定义打印模板（页眉、页脚），支持背景图形。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "TikZJax Rendering: Adapt diagrams dynamically to light and dark themes.",
          "target": "TikZJax 渲染：图表动态适应明暗主题。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Custom Notes: Assign custom keyboard shortcuts to instantly open preferred notes.",
