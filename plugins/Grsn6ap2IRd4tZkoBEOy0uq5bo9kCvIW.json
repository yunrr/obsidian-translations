{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "brain-dump-mode",
    "version": "2.0.0",
    "title": "Brain Dump Mode",
    "description": "Done is better than perfect. Complete your first-messy-draft before you make it perfect. Your delete key will be DISABLED and all you can do is JUST BURN YOUR KEYBOARDS🔥",
    "language": "zh-cn",
    "supportedVersions": "1.1.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(`Brain Dump Mode \\u{1F525} Backspace DISABLED`)",
          "target": "Notice(`Brain Dump 模式 \\u{1F525} 已禁用退格键`)"
        },
        {
          "source": ".setName(\"Enable brain dump mode\")",
          "target": ".setName(\"启用 brain dump 模式\")"
        },
        {
          "source": ".setName(\"Enable shark mode\")",
          "target": ".setName(\"启用鲨鱼模式\")"
        },
        {
          "source": ".setName(\"Your speed goal (minute)\")",
          "target": ".setName(\"速度目标(分钟)\")"
        },
        {
          "source": ".setName(\"Speed measure window (milliseconds)\")",
          "target": ".setName(\"测速窗口(毫秒)\")"
        },
        {
          "source": ".setDesc(\"If turned on, delete key will be disabled\")",
          "target": ".setDesc(\"如果打开，删除键将被禁用\")"
        },
        {
          "source": ".setDesc(\"Escape from the shark by typing fast \\u{1F988}\")",
          "target": ".setDesc(\"通过快速打字逃离鲨鱼 \\u{1F988}\")"
        },
        {
          "source": ".setDesc(\"How fast can you type?\")",
          "target": ".setDesc(\"你能打字多快？\")"
        },
        {
          "source": ".setDesc(\"Lower, the harder.\")",
          "target": ".setDesc(\"越低越难。\")"
        }
      ]
    }
  }
}