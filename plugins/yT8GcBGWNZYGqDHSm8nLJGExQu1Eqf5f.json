        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Render math in display mode, which puts the math in display style (so \\int and \\sum are large, for example), and centers the math on the page on its own line.",
          "target": "以显示模式渲染数学公式，这会将数学公式置于显示样式中（例如，\\\\int 和 \\\\sum 会变大），并将数学公式居中显示在页面的独立行上。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Determines the markup language of the output.",
          "target": "确定输出的标记语言。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Render display math in leqno style (left-justified tags).",
          "target": "以 leqno 样式（左对齐标签）渲染显示数学公式。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Render display math flush left.",
          "target": "将显示数学公式左对齐渲染。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Specifies a minimum thickness, in ems, for fraction lines, `\\sqrt` top lines, `{array}` vertical lines, `\\hline`, `\\hdashline`, `\\underline`, `\\overline`, and the borders of `\\fbox`, `\\boxed`, and `\\fcolorbox`.",
          "target": "指定分数线、`\\\\sqrt` 顶线、`{array}` 垂直线、`\\\\hline`、`\\\\hdashline`、`\\\\underline`、`\\\\overline` 以及 `\\\\fbox`、`\\\\boxed` 和 `\\\\fcolorbox` 边框的最小厚度，单位为 em。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Makes \\color behave like LaTeX's 2-argument \\textcolor, instead of LaTeX's one-argument \\color mode change.",
          "target": "使 \\\\color 的行为类似于 LaTeX 的双参数 \\\\textcolor，而不是 LaTeX 的单参数 \\\\color 模式更改。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Turn on strict / LaTeX faithfulness mode, which throws an error if the input uses features that are not supported by LaTeX.",
          "target": "开启严格 / LaTeX 忠实模式，如果输入使用了 LaTeX 不支持的功能，将抛出错误。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Trust the input, enabling all HTML features such as \\url.",
          "target": "信任输入，启用所有 HTML 功能，例如 \\\\url。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "If non-zero, all user-specified sizes, e.g. in \\rule{500em}{500em}, will be capped to maxSize ems. Otherwise, elements and spaces can be arbitrarily large",
          "target": "如果非零，所有用户指定的尺寸（例如在 \\\\rule{500em}{500em} 中）将被限制为最大 maxSize em。否则，元素和空间可以任意大。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Limit the number of macro expansions to the specified number, to prevent e.g. infinite macro loops. If set to Infinity, the macro expander will try to fully expand as in LaTeX.",
          "target": "将宏展开次数限制为指定数量，以防止例如无限宏循环。如果设置为 Infinity，宏展开器将尝试像 LaTeX 一样完全展开。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Fast math typesetting for the web.",
          "target": "适用于 Web 的快速数学排版。"
        },
