{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "lyrics",
    "version": "2.0.0",
    "title": "Lyrics",
    "description": "Enhance the audio player with interacive lyrics",
    "language": "zh-cn",
    "supportedVersions": "1.1.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "text: \"\",\n  timestr: \"",
          "target": "text: \"\",\n  timestr: \""
        },
        {
          "source": ".setName(\"Auto scroll\")",
          "target": ".setName(\"自动滚动\")"
        },
        {
          "source": ".setName(\"Sentence mode\")",
          "target": ".setName(\"句子模式\")"
        },
        {
          "source": ".setDesc(\"Whether enable auto-scroll by default\")",
          "target": ".setDesc(\"是否默认启用自动滚动\")"
        },
        {
          "source": ".setDesc(\"Whether enable sentence mode by default\")",
          "target": ".setDesc(\"是否默认开启句子模式\")"
        },
        {
          "source": ".appendText(\n              `Error: Invalid source ${this.audioPath}.\n\t\t\t\t\t\t\t`\n            )",
          "target": ".appendText(\n              `Error: Invalid source ${this.audioPath}.\n\t\t\t\t\t\t\t`\n            )"
        },
        {
          "source": ".setTitle(\"Play\")",
          "target": ".setTitle(\"播放\")"
        },
        {
          "source": ".setTitle(\"Pause\")",
          "target": ".setTitle(\"暂停\")"
        },
        {
          "source": ".setTitle(\"Seek\")",
          "target": ".setTitle(\"重放\")"
        },
        {
          "source": ".setTitle(\"Edit\")",
          "target": ".setTitle(\"编辑\")"
        },
        {
          "source": ".setTitle(\"Copy current timestamp\")",
          "target": ".setTitle(\"复制当前时间戳\")"
        },
        {
          "source": ".setTitle(\"Auto-scroll\")",
          "target": ".setTitle(\"自动滚动\")"
        },
        {
          "source": ".setTitle(\"Sentence mode\")",
          "target": ".setTitle(\"句子模式\")"
        },
        {
          "source": ".setTitle(\"Only show marked\")",
          "target": ".setTitle(\"仅显示已标记的\")"
        }
      ]
    }
  }
}