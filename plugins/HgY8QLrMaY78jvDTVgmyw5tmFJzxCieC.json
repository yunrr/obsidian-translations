        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Add an index-entry category for tagging concepts that should appear in a printed index. Pairs with the pandoc filter shipped under docs in the plugin repository.",
          "target": "为需要出现在印刷索引中的概念添加索引条目类别。与插件仓库docs目录下提供的pandoc过滤器配合使用。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Selected in the add-comment modal by default.",
          "target": "在添加评论模态框中默认选中。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "How comments are surfaced in the editor. The underline marks the text the comment was made against. The icon marks the comment's location when no text was selected at create time.",
          "target": "评论在编辑器中的呈现方式。下划线标记评论所针对的文本。图标标记在创建时未选择文本时的评论位置。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Visual size of the marker icon in the editor.",
          "target": "编辑器中标记图标的视觉大小。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Visual character of the underline drawn over commented text. Applies to every category.",
          "target": "在评论文本上绘制的下划线的视觉特征。适用于所有类别。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Baseline thickness for categories on the normal tier. Subtle always renders thin, strong always renders thick, regardless of this setting.",
          "target": "普通层级上类别的基准粗细。微妙模式始终渲染为细线，强烈模式始终渲染为粗线，不受此设置影响。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Whether comments are visible when a file opens.",
          "target": "文件打开时评论是否可见。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "How resolved comments appear in the editor.",
          "target": "已解决的评论在编辑器中的显示方式。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Resolving a comment permanently removes it from the file instead of keeping it as a dimmed [resolved] marker. The thread and its replies are gone; rely on git or backups for history. The separate \"Resolve and remove\" action always asks first; with this on, plain Resolve removes without asking.",
          "target": "解决评论会将其从文件中永久移除，而不是保留为变暗的[已解决]标记。讨论串及其回复将消失；请依赖git或备份来保留历史记录。单独的“解决并移除”操作总会先询问；启用此选项后，普通的“解决”操作会直接移除而不询问。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "How aggressively resolved comments are dimmed. Normal works well in light themes; bright keeps resolved content legible against dark backgrounds where the base text is already muted.",
          "target": "已解决评论的变暗程度。普通模式在浅色主题下效果良好；明亮模式在深色背景上保持已解决内容的可读性，因为基础文本本身已经变暗。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Where the add-comment form appears. The side panel keeps the document visible while you draft.",
          "target": "添加评论表单出现的位置。侧边面板可在您起草时保持文档可见。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Comments are invisible in reading view (markers are HTML comments). Show a note-level banner with totals, a badge on each section that has comments, or both. Click an indicator to open the comment panel. Counts are threads; replies are not counted.",
          "target": "在阅读视图中评论不可见（标记为HTML注释）。显示一个包含总数的笔记级横幅、每个有评论的章节上的徽章，或两者都显示。点击指示器可打开评论面板。计数为讨论串数；回复不计入。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "When the thread panel shows comments from multiple files, collapse files other than the one you are editing. Click a file header to expand it manually.",
          "target": "当讨论串面板显示来自多个文件的评论时，折叠除您正在编辑的文件之外的其他文件。点击文件标题可手动展开。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "When enabled, new comments include an [author=...] line. Useful when collaborating with an AI agent or multiple reviewers.",
          "target": "启用后，新评论将包含一个[author=...]行。在与AI代理或多个审阅者协作时很有用。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Short tag with no spaces; maximum 32 characters.",
          "target": "不含空格的短标签；最多32个字符。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Vault folder the exported skill file is written to. Claude Code reads .claude/skills; some other assistants read a .agent folder.",
          "target": "导出的技能文件写入的保险库文件夹。Claude Code读取.claude/skills；其他一些助手读取.agent文件夹。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Log additional information for troubleshooting. Off by default to avoid log spam.",
          "target": "记录额外信息以进行故障排除。默认关闭以避免日志泛滥。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Where diagnostic output is written.",
          "target": "诊断输出的写入位置。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Cherry-pick categories from any preset into your working list. Picking a preset never replaces existing categories.",
