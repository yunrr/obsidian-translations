    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(noticeMessage)",
          "target": "Notice(noticeMessage)"
        },
        {
          "source": "Notice(\"Nothing inside your node\")",
          "target": "Notice(\"您的文件内部为空\")"
        },
        {
          "source": "Notice(\"No persons were found\")",
          "target": "Notice(\"未找到人物\")"
        },
        {
          "source": "Notice(\n      `Node could not be found at location: ${this.settings.birthdayNodeLocation}`\n    )",
          "target": "Notice(\n      `未能在位置找到文件: ${this.settings.birthdayNodeLocation}`\n    )"
        },
        {
          "source": "Notice(\n      message.concat(\n        `${personsBirthdayToday.length > 1 ? \" have\" : \" has\"} birthday`\n      )",
          "target": "Notice(\n      message.concat(\n        `${personsBirthdayToday.length > 1 ? \" have\" : \" has\"} birthday`\n      )"
        },
        {
          "source": "name: \"Track Birthdays\"",
          "target": "name: \"跟踪生日\""
        },
        {
          "source": "name: \"Search Person\"",
          "target": "name: \"搜索人物\""
        },
        {
          "source": "name: \"Year Overview\"",
          "target": "name: \"年度概览\""
        },
        {
