          "target": "Notice(\"无效数字\")"
        },
        {
          "source": ".log(\"Stuck with token \"+this.parser.getName(this.tokens.mainToken.value)",
          "target": ".log(\"卡在词元 \"+this.parser.getName(this.tokens.mainToken.value)"
        },
        {
          "source": ".error(\"Last ten effects were: \",yr.slice(-10)",
          "target": ".error(\"最后十个效果是: \",yr.slice(-10)"
        },
        {
          "source": ".error(\"Container not found\")",
          "target": ".error(\"容器未找到\")"
        },
        {
          "source": "name:\"Filename\"",
          "target": "name:\"文件名\""
        },
        {
          "source": "name:\"Open card view\"",
          "target": "name:\"打开卡片视图\""
        },
        {
          "source": ".setButtonText(\"Reset\")",
          "target": ".setButtonText(\"重置\")"
        },
        {
