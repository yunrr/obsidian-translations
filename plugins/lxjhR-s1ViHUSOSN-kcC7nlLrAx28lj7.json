        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Desktop App only.",
          "target": "仅限桌面应用。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Defers initialization at startup (Unstable on mobile). Reduces startup time but delays first render.",
          "target": "在启动时延迟初始化（在移动端不稳定）。可减少启动时间，但会延迟首次渲染。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "When a package is imported, the cache is used instead of the actual files for faster performance. If you make changes directly, please click the package icon to refresh the cache (plugin reload is required.)",
          "target": "导入包时，将使用缓存而非实际文件以提升性能。如果您直接进行了更改，请点击包图标刷新缓存（需要重新加载插件）。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Conceal math symbols (e.g. integral to ∫) in the editor.",
          "target": "在编辑器中隐藏数学符号（例如将积分符号显示为 ∫）。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Enable delay before revealing concealed math symbols when cursor is nearby.",
          "target": "当光标靠近时，启用延迟再显示隐藏的数学符号。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Milliseconds to wait before revealing the symbol text.",
          "target": "显示符号文本前等待的毫秒数。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Automatically replaces typed symbols with Unicode equivalents.",
          "target": "自动将输入的符号替换为对应的 Unicode 字符。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Disable highlighting of matching brackets.",
          "target": "禁用匹配括号的高亮显示。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Show live preview for inline math.",
          "target": "显示行内数学公式的实时预览。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Reverts the Tab key behavior to the default indentation instead of jumping to the next placeholder.",
