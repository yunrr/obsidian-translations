        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "When exiting math, first move the cursor to the end of the block.",
          "target": "退出数学模式时，先将光标移至块末尾。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "If a display math block fits on a single line, exit inline instead of creating a new line.",
