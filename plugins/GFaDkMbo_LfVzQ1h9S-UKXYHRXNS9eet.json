{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "editor-width-slider",
    "version": "2.0.0",
    "title": "Editor Width Slider",
    "description": "Customize Obsidian's editor width with a slider for a tailored editing experience.",
    "language": "zh-cn",
    "supportedVersions": "1.0.5",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(\"Slider value:\", value)",
          "target": ".log(\"滑块值：\", value)"
        },
        {
          "source": ".log(\"test\")",
          "target": ".log(\"test\")"
        },
        {
          "source": ".log(\"2\")",
          "target": ".log(\"2\")"
        },
        {
          "source": ".log(\"1.1\")",
          "target": ".log(\"1.1\")"
        },
        {
          "source": ".log(\"1.2\")",
          "target": ".log(\"1.2\")"
        },
        {
          "source": ".error(\"Error:\", e.message)",
          "target": ".error(\"错误：\", e.message)"
        },
        {
          "source": ".setText(\"Editor width must be a number from 0 to 100!\")",
          "target": ".setText(\"编辑器宽度必须是 0 到 100 之间的数字！\")"
        },
        {
          "source": ".setName(\"Slider Width\")",
          "target": ".setName(\"滑块宽度\")"
        },
        {
          "source": ".setName(\"Slider Default Percentage\")",
          "target": ".setName(\"滑块默认百分比\")"
        },
        {
          "source": ".setName(\"Note:\")",
          "target": ".setName(\"注意：该字段应在注释的 YAML frontmatter 中命名为 “editor-width”，以便自定义该注释的编辑器宽度。除非您在每个注释的 frontmatter 中指定它，否则它不会全局适用于所有注释。\")"
        },
        {
          "source": ".setDesc(\"How wide do you want your slider to be?\")",
          "target": ".setDesc(\"你希望你的滑块有多宽？\")"
        },
        {
          "source": ".setDesc(\"What do you want the default percentage of the slider to be?\")",
          "target": ".setDesc(\"您希望滑块的默认百分比是多少？\")"
        },
        {
          "source": ".setPlaceholder(\"Slider width in px\")",
          "target": ".setPlaceholder(\"滑块宽度 （px）\")"
        }
      ]
    }
  }
}