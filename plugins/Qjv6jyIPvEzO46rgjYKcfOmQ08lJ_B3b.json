{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "manual-sorting",
    "version": "2.0.0",
    "title": "Manual Sorting",
    "description": "Drag'n'Drop file sorting.",
    "language": "zh-cn",
    "supportedVersions": "2.0.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "text:\"Are you sure you want to reset order to default?\"",
          "target": "text:\"你确定要恢复为默认排序吗？\""
        },
        {
          "source": ".setButtonText(\"Yep\")",
          "target": ".setButtonText(\"确认\")"
        },
        {
          "source": ".setButtonText(\"Cancel\")",
          "target": ".setButtonText(\"拒绝\")"
        },
        {
          "source": ".setTitle(\"Manual sorting\")",
          "target": ".setTitle(\"手动排序\")"
        },
        {
          "source": ".setTitle(\"\\u{1F4CC} Manual sorting\")",
          "target": ".setTitle(\"\\u{1F4CC} 手动排序\")"
        },
        {
          "source": ".setTitle(\"\\u{1F5D1}\\uFE0F Reset order\")",
          "target": ".setTitle(\"\\u{1F5D1}\\uFE0F 重置排序\")"
        },
        {
          "source": "u.setTitle(\"Reset order\")",
          "target": "u.setTitle(\"重置排序\")"
        },
        {
          "source": "u.setTitle(\"Dragging\"",
          "target": "u.setTitle(\"拖拽排序\""
        }
      ]
    }
  }
}