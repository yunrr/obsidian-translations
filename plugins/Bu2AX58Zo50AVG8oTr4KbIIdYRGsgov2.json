{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "find-and-replace-in-selection",
    "version": "2.0.0",
    "title": "Find and replace in selection",
    "description": "Finds what you are looking for in the selected text and replaces it with the specified text",
    "language": "zh-cn",
    "supportedVersions": "1.0.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setName('Text to find')",
          "target": ".setName('要查找的文本')"
        },
        {
          "source": ".setName('RegExp to find')",
          "target": ".setName('正则表达式查找')"
        },
        {
          "source": ".setName('Replace by')",
          "target": ".setName('替换为')"
        },
        {
          "source": ".setDesc('Leave empty to ignore')",
          "target": ".setDesc('留空以忽略')"
        },
        {
          "source": ".setDesc('Text to be inserted')",
          "target": ".setDesc('待插入的文本')"
        },
        {
          "source": ".setPlaceholder('Example: (\\w+)\\s(\\w+)')",
          "target": ".setPlaceholder('示例：(\\w+)\\s(\\w+)')"
        },
        {
          "source": ".setPlaceholder('Example: gmi')",
          "target": ".setPlaceholder('示例：gmi')"
        },
        {
          "source": ".setPlaceholder('Example: $2, $1')",
          "target": ".setPlaceholder('示例：$2, $1')"
        },
        {
          "source": "name: 'Find and replace in selection'",
          "target": "name: '在选中的内容中查找和替换'"
        },
        {
          "source": "text: 'Find and replace in selection - Settings'",
          "target": "text: '在选中的内容中查找和替换—设置'"
        },
        {
          "source": ".setName('RegExp flags')",
          "target": ".setName('正则表达式标识符')"
        },
        {
          "source": ".setDesc('Type \"gmi\" for global, multiline, insensitive')",
          "target": ".setDesc('键入\"gmi\" 表示开启 全局、多行、大小写不敏感')"
        }
      ]
    }
  }
}