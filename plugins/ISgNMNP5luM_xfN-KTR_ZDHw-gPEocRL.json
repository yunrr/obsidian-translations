          "source": "setDesc(\"Show the text inside callout blocks\"",
          "target": "setDesc(\"显示 callout 块内的文本\""
        },
        {
          "source": "setDesc(\"Show link to original note\"",
          "target": "setDesc(\"显示指向原始笔记的链接\""
        },
        {
          "source": "setDesc(\"Remove tags from text\"",
          "target": "setDesc(\"从文本中删除标签\""
        },
        {
          "source": "setDesc(\"Include only the items of a list that contain the tag, not the entire list.\"",
          "target": "setDesc(\"仅包括包含标签的列表中的项，而不是整个列表\""
        },
        {
          "source": "setDesc(\"Include the child items of a list.\"",
          "target": "setDesc(\"包括列表中的子项.\""
        },
        {
          "source": "setName(\"Show Callouts\"",
