          "type": "CallExpression",
          "name": "warn",
          "source": "Warning: KaTeX doesn't work in quirks mode. Make sure your website has a suitable doctype.",
          "target": "警告：KaTeX在怪异模式下无法工作。请确保您的网站有合适的文档类型声明。"
        },
        {
          "type": "NewExpression",
          "name": "Notice",
          "source": "No active Markdown file.",
          "target": "没有活动的Markdown文件。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Render math in display mode, which puts the math in display style (so \\int and \\sum are large, for example), and centers the math on the page on its own line.",
          "target": "以显示模式渲染数学公式，这会将数学公式置于显示样式（例如，\\\\int和\\\\sum会变大），并将数学公式居中显示在页面的独立行上。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Determines the markup language of the output.",
          "target": "确定输出的标记语言。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Render display math in leqno style (left-justified tags).",
          "target": "以leqno样式（左对齐标签）渲染显示数学公式。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Render display math flush left.",
          "target": "将显示数学公式左对齐渲染。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Specifies a minimum thickness, in ems, for fraction lines, `\\sqrt` top lines, `{array}` vertical lines, `\\hline`, `\\hdashline`, `\\underline`, `\\overline`, and the borders of `\\fbox`, `\\boxed`, and `\\fcolorbox`.",
          "target": "指定分数线、`\\\\sqrt`顶线、`{array}`垂直线、`\\\\hline`、`\\\\hdashline`、`\\\\underline`、`\\\\overline`以及`\\\\fbox`、`\\\\boxed`和`\\\\fcolorbox`边框的最小厚度，单位为em。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Makes \\color behave like LaTeX's 2-argument \\textcolor, instead of LaTeX's one-argument \\color mode change.",
          "target": "使\\\\color的行为类似于LaTeX的2参数\\\\textcolor，而不是LaTeX的单参数\\\\color模式更改。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Turn on strict / LaTeX faithfulness mode, which throws an error if the input uses features that are not supported by LaTeX.",
          "target": "开启严格/忠实于LaTeX的模式，如果输入使用了LaTeX不支持的功能，则会抛出错误。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Trust the input, enabling all HTML features such as \\url.",
          "target": "信任输入，启用所有HTML功能，如\\\\url。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "If non-zero, all user-specified sizes, e.g. in \\rule{500em}{500em}, will be capped to maxSize ems. Otherwise, elements and spaces can be arbitrarily large",
          "target": "如果非零，所有用户指定的大小（例如在\\\\rule{500em}{500em}中）将被限制为maxSize em。否则，元素和空格可以任意大。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Limit the number of macro expansions to the specified number, to prevent e.g. infinite macro loops. If set to Infinity, the macro expander will try to fully expand as in LaTeX.",
          "target": "将宏展开次数限制为指定次数，以防止例如无限宏循环。如果设置为Infinity，宏展开器将尝试像LaTeX一样完全展开。"
        },
