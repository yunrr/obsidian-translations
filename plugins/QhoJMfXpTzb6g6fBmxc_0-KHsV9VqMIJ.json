        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick gains proficiency in one saving throw of your choice",
          "target": "助手获得一项你选择的豁免熟练项。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick gains proficiency in five skills of your choice.",
          "target": "助手获得五项你选择的技能熟练项。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "light armor",
          "target": "轻甲"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "all simple weapons",
          "target": "所有简易武器"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick can take the Help action as a bonus action.",
          "target": "助手可以将“协助”动作作为附赠动作执行。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "On its turn in combat, the sidekick can take the Dash, Disengage, or Hide action as a bonus action.",
          "target": "在战斗中，助手可以将“冲刺”、“脱离接触”或“躲藏”动作作为附赠动作执行。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Choose two of the sidekick's skill proficiencies. The sidekick's proficiency bonus is doubled for any ability check it makes that uses any of the chosen proficiencies.",
          "target": "选择助手的两项技能熟练项。助手进行任何使用所选熟练项的属性检定时，其熟练加值翻倍。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick increases one ability score of your choice by 2, or the sidekick increases two ability scores of your choice by 1. The sidekick can't increase an ability score above 20 using this feature.",
          "target": "助手将你选择的一项属性值提高2点，或将你选择的两项属性值各提高1点。助手无法使用此特性将属性值提高到20以上。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "When the sidekick is subjected to an effect that allows it to make a Dexterity saving throw to take only half damage, it instead takes no damage if it succeeds on the saving throw, and only half damage if it failed. The sidekick doesn't benefit from this feature while incapacitated.",
          "target": "当助手受到允许其进行敏捷豁免检定以只承受一半伤害的效果影响时，如果豁免成功则不受伤害，如果豁免失败则只承受一半伤害。助手在失去意识时无法受益于此特性。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Whenever the sidekick makes an ability check that includes its whole proficiency bonus, it can treat a d20 roll of 9 or lower as a 10.",
          "target": "每当助手进行包含其全部熟练加值的属性检定时，它可以将9或更低的d20骰结果视为10。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Sharp Mind: The sidekick gains proficiency in one saving throw of your choice.",
          "target": "敏锐心智：助手获得一项你选择的豁免熟练项。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick gains gain proficiency in one saving throw of your choice",
          "target": "助手获得一项你选择的豁免熟练项。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick gains the ability to cast spells. Choose the Spellcaster's role: Mage, Healer, or Prodigy. This choice determines the spell list and spellcasting ability used by the sidekick.",
          "target": "助手获得施法能力。选择施法者的角色：法师、治疗师或奇才。此选择决定了助手使用的法术列表和施法属性。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Spell List: Wizard - Spellcasting Ability: Intelligence",
          "target": "法术列表：法师 - 施法属性：智力"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Spell Lists: Cleric and Druid - Spellcasting Ability: Wisdom",
          "target": "法术列表：牧师和德鲁伊 - 施法属性：感知"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Spell Lists: Bard and Warlock - Spellcasting Ability: Charisma",
          "target": "法术列表：吟游诗人和邪术师 - 施法属性：魅力"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick can add its spellcasting ability modifier to the damage it deals with any cantrip.",
          "target": "助手可以将其施法属性调整值加到其施展的任何戏法造成的伤害上。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Choose one school of magic. Whenever the sidekick casts a spell of that school by expending a spell slot, the sidekick can add its spellcasting ability modifier to the spell's damage roll or healing roll, if any.",
          "target": "选择一个魔法学派。每当助手消耗一个法术位施展该学派的法术时，助手可以将其施法属性调整值加到该法术的伤害骰或治疗骰上（如果有的话）。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Taking damage can't break the sidekick's concentration on a spell.",
          "target": "受到伤害不会中断助手对法术的专注。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick gains proficiency in two skills of your choice",
          "target": "助手获得两项你选择的技能熟练项。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "all armor",
          "target": "所有护甲"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "all simple and martial weapons",
          "target": "所有简易和军用武器"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "shields",
          "target": "盾牌"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Each warrior focuses on offense or defense in their training. Choose one of the following options:",
          "target": "每位战士在训练中专注于进攻或防御。选择以下选项之一："
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick gains a + 2 bonus to all attack rolls (already included).",
          "target": "助手获得所有攻击骰+2加值（已包含）。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick can use its reaction to impose disadvantage on the attack roll of a creature within 5 feet of it whose target isn't the sidekick, provided the sidekick can see the attacker.",
          "target": "助手可以使用其反应，对5英尺内目标不是助手的生物的攻击骰施加劣势，前提是助手能看到攻击者。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Once per short or long rest, the sidekick can use a bonus action on its turn to regain hit points equal to 1d10 + its level in this class.",
          "target": "每短休或长休一次，伙伴可以使用一个附赠动作恢复等于1d10+其此职业等级的生命值。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick's attack rolls score a critical hit on a roll of 19 or 20 on the d20.",
          "target": "伙伴的攻击检定在d20骰投出19或20时命中即为重击。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick can attack twice, instead of once, whenever it takes the Attack action on its turn. If the sidekick has the Multiattack action, it can use Extra Attack or Multiattack on a turn, not both.",
          "target": "每当伙伴在其回合采取攻击动作时，它可以攻击两次，而非一次。如果伙伴拥有多重攻击动作，它可以在一个回合内使用额外攻击或多重攻击，但不能同时使用两者。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick has advantage on initiative rolls.",
          "target": "伙伴在先攻检定上具有优势。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick's Armor Class increases by 1 (already iuncluded).",
          "target": "伙伴的护甲等级增加1（已包含）。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Once per long rest, the sidekick can reroll a saving throw that it fails, but it must use the new roll.",
          "target": "每长休一次，伙伴可以重投一次失败的豁免检定，但必须使用新的结果。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "The sidekick can attack three times, instead of once, whenever it takes the Attack action on its turn. If the sidekick has the Multiattack action, it can use Extra Attack or Multiattack on a turn, not both.",
          "target": "每当伙伴在其回合采取攻击动作时，它可以攻击三次，而非一次。如果伙伴拥有多重攻击动作，它可以在一个回合内使用额外攻击或多重攻击，但不能同时使用两者。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Twice per long rest, the sidekick can reroll a saving throw that it fails, but it must use the new roll.",
          "target": "每长休两次，伙伴可以重投一次失败的豁免检定，但必须使用新的结果。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Twice per short or long rest, the sidekick can use a bonus action on its turn to regain hit points equal to 1d10 + its level in this class.",
          "target": "每短休或长休两次，伙伴可以使用一个附赠动作恢复等于1d10+其此职业等级的生命值。"
