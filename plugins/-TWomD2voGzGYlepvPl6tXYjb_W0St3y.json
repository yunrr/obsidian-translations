{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "hover-reveal",
    "version": "2.0.0",
    "title": "Hover Reveal",
    "description": "Shows hidden text in tooltips when hovering over marked elements using [visibleText]{tooltipText} syntax.",
    "language": "zh-cn",
    "supportedVersions": "1.0.5",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(\"Reset settings to default\")",
          "target": "Notice(\"将设置重置为默认值\")"
        },
        {
          "source": ".setButtonText(\"Reset\")",
          "target": ".setButtonText(\"重置\")"
        },
        {
          "source": ".setName(\"Reset settings\")",
          "target": ".setName(\"重置设置\")"
        },
        {
          "source": ".setName(\"Tooltip text color\")",
          "target": ".setName(\"Tooltip文本色\")"
        },
        {
          "source": ".setName(\"Tooltip background color\")",
          "target": ".setName(\"Tooltip背景色\")"
        },
        {
          "source": ".setName(\"Tooltip border color\")",
          "target": ".setName(\"Tooltip边框色\")"
        },
        {
          "source": ".setName(\"Bold text color\")",
          "target": ".setName(\"加粗文本色\")"
        },
        {
          "source": ".setDesc(\"Reset all settings to default values\")",
          "target": ".setDesc(\"将所有设置重置为默认值。\")"
        },
        {
          "source": ".setDesc(\"Set the text color of the tooltip\")",
          "target": ".setDesc(\"设置文字颜色\")"
        },
        {
          "source": ".setDesc(\"Set the background color of the tooltip\")",
          "target": ".setDesc(\"设置背景颜色\")"
        },
        {
          "source": ".setDesc(\"Set the border color of the tooltip\")",
          "target": ".setDesc(\"设置边框颜色。\")"
        },
        {
          "source": ".setDesc(\"Set the color of the bold text\")",
          "target": ".setDesc(\"设置加粗文本色\")"
        }
      ]
    }
  }
}