        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Use double plus (\"++\") as a delimiter.",
          "target": "使用双加号（\\\"++\\\"）作为分隔符。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Use double bars (\"||\") as a delimiter.",
          "target": "使用双竖线（\\\"||\\\"）作为分隔符。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Use a single caret (\"^\") as a delimiter.",
          "target": "使用单个脱字符（\\\"^\\\"）作为分隔符。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Use a single tilde (\"~\") as a delimiter.",
          "target": "使用单个波浪号（\\\"~\\\"）作为分隔符。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Use alphanumeric and hyphen characters (\"A-Za-z0-9-\") after the opening delimiter covered by curly brackets (\"{}\").",
          "target": "在由花括号（\\\"{}\\\"）覆盖的起始分隔符后，使用字母数字和连字符（\\\"A-Za-z0-9-\\\"）。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Use double exclamation marks (\"!!\") as a delimiter. Can be inserted after the opening delimiter by a tag with the same way as highlight tag. Additionally, you can use multiple classes inside it, separated by space(s).",
          "target": "使用双感叹号（\\\"!!\\\"）作为分隔符。可以在起始分隔符后通过标签插入，方式与高亮标签相同。此外，可以在其中使用多个类名，用空格分隔。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Use three colons (\":::\") or more at the beginning of a paragraph, followed by alphanumeric and hyphen character (\"A-Za-z0-9\") after them. Use space to separate each class.",
          "target": "在段落开头使用三个或更多冒号（\\\":::\\\"），后跟字母数字和连字符（\\\"A-Za-z0-9\\\"）。使用空格分隔每个类名。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Will automatically open tag menu after doing formatting via command palattes or context menu. Only applied to the custom highlight, custom span, and fenced div.",
          "target": "通过命令面板或上下文菜单进行格式化后，将自动打开标签菜单。仅适用于自定义高亮、自定义跨度和围栏div。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Prevent any fenced divs being styled in source mode.",
          "target": "防止在源代码模式下为任何围栏div设置样式。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Tags can either always be visible, or when they meet particular condition.",
          "target": "标签可以始终可见，或仅在满足特定条件时可见。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Show or hide highlight color tag in the preview mode.",
          "target": "在预览模式下显示或隐藏高亮颜色标签。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Show or hide custom span tag in the preview mode.",
          "target": "在预览模式下显示或隐藏自定义跨度标签。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "By default, the tag is always hidden in the preview mode, and only displayed when touching the cursor or selection in the live preview mode.",
          "target": "默认情况下，标签在预览模式下始终隐藏，仅在实时预览模式下触碰光标或选择时显示。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Display a button after highlight opening delimiter, used to open the color menu.",
          "target": "在高亮起始分隔符后显示一个按钮，用于打开颜色菜单。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Show accent option in the color menu.",
          "target": "在颜色菜单中显示强调色选项。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Show default option in the color menu. Default means non-tagged highlight.",
          "target": "在颜色菜单中显示默认选项。默认表示无标签的高亮。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Show remove option in the color menu.",
          "target": "在颜色菜单中显示移除选项。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Adjust highlight opacity in light mode. Zero means that will be fully transparent.",
          "target": "调整浅色模式下的高亮不透明度。零表示完全透明。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
