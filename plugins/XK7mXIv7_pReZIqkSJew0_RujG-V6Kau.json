        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "The Midnight Line waits at the far platform. {traveler} has a ticket, a lantern, and a watch no one should recognize.",
          "target": "午夜列车停在远处的站台。{traveler} 有一张车票、一盏提灯，以及一块无人应识的怀表。"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "A visual frame for the station-side beats. This one is not an Events Sheet row.",
          "target": "用于车站侧情节节拍的视觉框架。这并非事件表中的一行。"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "Custom Story Sequence frame. Event Frame is the behavior type; this is one concrete class built on it.",
          "target": "自定义故事序列框架。事件框架是行为类型；这是基于它构建的一个具体类。"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "Fog swallows the rails. The watch once owned by @Old Reyes is heavier than it looks in {traveler}'s coat.",
          "target": "雾气吞没了铁轨。曾属于 @老雷耶斯 的怀表，在 {traveler} 的外套口袋里显得比看起来更沉。"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "Tickets, please. {traveler}, is it? The Line has been waiting for that watch.",
          "target": "请出示车票。{traveler}，对吗？列车一直在等那块怀表。"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "lantern_lit = true",
          "target": "lantern_lit = true"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "Choice, Set, and branch outcome nodes inside the custom Story Sequence event-frame class.",
          "target": "自定义故事序列事件框架类内的选择、设置和分支结果节点。"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "A gloved hand opens between you and the aisle.",
          "target": "一只戴着手套的手在你和过道之间伸出。"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "trust_level = 2",
          "target": "trust_level = 2"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
          "source": "Radio check. If the lantern is lit, follow the blue carriage marks.",
          "target": "无线电确认。如果提灯亮着，请跟随蓝色车厢标记。"
        },
        {
          "type": "ObjectProperty",
          "name": "body",
