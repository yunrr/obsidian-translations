{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "autofit-tabs",
    "version": "2.0.0",
    "title": "Autofit Tabs",
    "description": "Automatically adjusts tab header widths in real-time to perfectly fit each tab's title content while maintaining a clean, seamless interface that prevents awkward text truncation and ensures optimal readability of your document titles.",
    "language": "zh-cn",
    "supportedVersions": "1.0.5",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "name:\"Close button padding\"",
          "target": "name:\"关闭按钮padding\""
        },
        {
          "source": "name:\"Transition duration\"",
          "target": "name:\"过渡动画持续时间\""
        },
        {
          "source": "name:\"Minimum width\"",
          "target": "name:\"最小宽度\""
        },
        {
          "source": "name:\"Max width\"",
          "target": "name:\"最大宽度\""
        },
        {
          "source": "name:\"Close button width\"",
          "target": "name:\"关闭按钮宽度\""
        },
        {
          "source": "name:\"Left padding\"",
          "target": "name:\"左padding\""
        },
        {
          "source": "name:\"Icon width\"",
          "target": "name:\"Icon宽度\""
        },
        {
          "source": "name:\"Icon right margin\"",
          "target": "name:\"Icon右margin\""
        },
        {
          "source": ".setDesc(`${s} (default: ${c[a]})`)",
          "target": ".setDesc(`${s} (default: ${c[a]})`)"
        },
        {
          "source": ".setDesc(`${o} (default: ${c[n]})`)",
          "target": ".setDesc(`${o} (default: ${c[n]})`)"
        }
      ]
    }
  }
}