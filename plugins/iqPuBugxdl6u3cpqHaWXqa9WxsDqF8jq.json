        {
          "type": "AssignmentExpression",
          "name": "innerHTML",
          "source": "<div class=\"setting-item-name\">Capture Comment in Browser</div> \n\t\t\t<div class=\"setting-item-description\">Display a modal in the browser to capture any comments before sending to\n\t\t\t\tObsidian?</div>",
