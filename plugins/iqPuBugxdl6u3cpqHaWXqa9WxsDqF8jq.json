        {
          "type": "AssignmentExpression",
          "name": "innerHTML",
          "source": "<div class=\"setting-item-name\">Store Clippings Per Domain</div> \n\t\t\t<div class=\"setting-item-description\">Creates a note per top-level domain and stores all clippings from that\n\t\t\t\tdomain within it. It will add an embedded document link in your Daily\n\t\t\t\tNote.</div>",
          "target": "<div class=\\\"setting-item-name\\\">按域名存储剪藏</div> \\n\\t\\t\\t<div class=\\\"setting-item-description\\\">为每个顶级域名创建一个笔记，并将该域名下的所有剪藏存储在其中。它将在您的每日笔记中添加一个嵌入式文档链接。</div>"
        },
