{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-file-cleaner",
    "version": "2.0.0",
    "title": "File Cleaner",
    "description": "Help you to clean empty files and unused attachments in the vault.",
    "language": "zh-cn",
    "supportedVersions": "0.1.5",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(t(\"Clean successful\")",
          "target": "Notice(t(\"清理成功\")"
        },
        {
          "source": "Notice(t(\"No file to clean\")",
          "target": "Notice(t(\"无文件需清理\")"
        },
        {
          "source": ".log(file.name + \" cleaned\")",
          "target": ".log(file.name + \"已清理\")"
        }
      ]
    }
  }
}