{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "weather-fetcher",
    "version": "2.0.0",
    "title": "Weather Fetcher",
    "description": "Fetch and insert current weather into the editor of Obsidian.",
    "language": "zh-cn",
    "supportedVersions": "0.0.3",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(\"No active editor, no output.\")",
          "target": "Notice(\"没有活动编辑器，没有输出。\")"
        },
        {
          "source": "Notice(\"Fetching weather...\")",
          "target": "Notice(\"获取天气。。。\")"
        },
        {
          "source": "Notice(\"Something goes wrong while fetching weather info.\")",
          "target": "Notice(\"获取天气信息时出错。\")"
        },
        {
          "source": "Notice(\"No cached weather info, no output.\")",
          "target": "Notice(\"没有缓存的天气信息，没有输出。\")"
        },
        {
          "source": ".log(\"loading WeatherPlugin\")",
          "target": ".log(\"正在加载WeatherPlugin\")"
        },
        {
          "source": ".log(\"unloading WeatherPlugin\")",
          "target": ".log(\"卸载WeatherPlugin\")"
        },
        {
          "source": ".error(e)",
          "target": ".error(e)"
        },
        {
          "source": "name: \"Insert current weather\"",
          "target": "name: \"插入当前天气\""
        },
        {
          "source": "name: \"Output current cached weather info. For debugging purposes.\"",
          "target": "name: \"输出当前缓存的天气信息。用于调试目的。\""
        },
        {
          "source": "text: `${this.plugin.manifest.name}`",
          "target": "text: `${this.plugin.manifest.name}`"
        },
        {
          "source": "text: \"License\"",
          "target": "text: \"许可证\""
        },
        {
          "source": "text: \"The source code of the plugin is released under Apache-2 license. See the repo for more information:\"",
          "target": "text: \"该插件的源代码在Apache-2许可证下发布。有关更多信息，请参阅repo：\""
        },
        {
          "source": ".setName(\"Data Provider\")",
          "target": ".setName(\"数据提供程序\")"
        },
        {
          "source": ".setName(\"Cache Time\")",
          "target": ".setName(\"缓存时间\")"
        },
        {
          "source": ".setName(\"Add Ribbon\")",
          "target": ".setName(\"添加功能区\")"
        },
        {
          "source": ".setDesc(\"After one call of weather api, the result will be cached for some minutes locally.\")",
          "target": ".setDesc(\"调用一次weather api后，结果将在本地缓存几分钟。\")"
        },
        {
          "source": ".setDesc(\"Add sidebar ribbon or not?\")",
          "target": ".setDesc(\"是否添加侧边栏功能区？\")"
        }
      ]
    }
  }
}