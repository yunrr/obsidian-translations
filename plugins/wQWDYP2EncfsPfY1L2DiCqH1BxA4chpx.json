{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "customjs",
    "version": "2.0.0",
    "title": "CustomJS",
    "description": "This plugin lets you use custom javascript files inside your vault.",
    "language": "zh-cn",
    "supportedVersions": "1.0.21",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(`${message}\\n${e.message}\\nSee error console for more details`)",
          "target": "Notice(`${message}\\n${e.message}\\nSee error console for more details`)"
        },
        {
          "source": ".error(e)",
          "target": ".error(e)"
        },
        {
          "source": ".error(`${deconstructor.name} failed`)",
          "target": ".error(`${deconstructor.name} failed`)"
        },
        {
          "source": ".error(`CustomJS couldn't import ${f}`)",
          "target": ".error(`CustomJS couldn't import ${f}`)"
        },
        {
          "source": "name: `Deconstructor of ${cls.constructor.name}`",
          "target": "name: `Deconstructor of ${cls.constructor.name}`"
        },
        {
          "source": "text : \"label\"",
          "target": "text : \"label\""
        },
        {
          "source": "text: 'CustomJS'",
          "target": "text: 'CustomJS'"
        },
        {
          "source": ".setButtonText('Add startup script')",
          "target": ".setButtonText('添加启动脚本')"
        },
        {
          "source": ".setName('Folder')",
          "target": ".setName('文件夹')"
        },
        {
          "source": ".setName('Registered invocable scripts')",
          "target": ".setName('已注册的可调用脚本')"
        },
        {
          "source": ".setName('Startup scripts')",
          "target": ".setName('启动脚本')"
        },
        {
          "source": ".setName('Re-execute the start scripts when reloading')",
          "target": ".setName('重新加载时重新执行启动脚本')"
        },
        {
          "source": ".setPlaceholder('jsfile1.js,jsfile2.js')",
          "target": ".setPlaceholder('jsfile1.js,jsfile2.js')"
        },
        {
          "source": ".setPlaceholder('js/scripts')",
          "target": ".setPlaceholder('js/scripts')"
        },
        {
          "source": ".setTooltip('Configure Hotkey')",
          "target": ".setTooltip('配置热键')"
        },
        {
          "source": ".log('Loading CustomJS')",
          "target": ".log('下载 CustomJS')"
        },
        {
          "source": ".error(message)",
          "target": ".error(消息)"
        },
        {
          "source": "name: 'Invoke Script'",
          "target": "name: 'Invoke Script'"
        },
        {
          "source": ".setButtonText('Register invocable script')",
          "target": ".setButtonText('注册可调用脚本')"
        },
        {
          "source": ".setName('Individual files')",
          "target": ".setName('单个文件')"
        },
        {
          "source": ".setDesc('Comma-separated list of files to load')",
          "target": ".setDesc('要加载的文件列表，以逗号分隔')"
        },
        {
          "source": ".setDesc('Path to folder containing JS files to load')",
          "target": ".setDesc('包含要加载的JS文件的文件夹的路径')"
        },
        {
          "source": ".setDesc('Decides whether the startup scripts should be executed again after reloading the scripts')",
          "target": ".setDesc('决定重新加载脚本后是否应该再次执行启动脚本')"
        },
        {
          "source": ".setTooltip('Delete')",
