{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "tag-wrangler",
    "version": "2.0.0",
    "title": "Tag Wrangler",
    "description": "Rename, merge, toggle, and search tags from the tag pane",
    "language": "zh-cn",
    "supportedVersions": "0.6.4",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(u+\"; skipping frontmatter\")",
          "target": "Notice(u+\"；跳过前置属性（frontmatter）\")"
        },
        {
          "source": "Notice(\"Unchanged or empty tag: No changes made.\")",
          "target": "Notice(\"未更改或空标签：未进行任何更改。\")"
        },
        {
          "source": "Notice(\"error: \"+i)",
          "target": "Notice(\"错误：\"+i)"
        },
        {
          "source": "name:\"all\"",
          "target": "name:\"所有\""
        },
        {
          "source": ".setTitle(\"WARNING: No Undo!\")",
          "target": ".setTitle(\"警告：不能撤消！\")"
        },
        {
          "source": ".setTitle(\"Create Tag Page\")",
          "target": ".setTitle(\"创建标签页\")"
        },
        {
          "source": "create-new",
          "target": "新建"
        },
        {
          "source": "Create tag page",
          "target": "创建标签页"
        },
        {
          "source": "Rename #",
          "target": "重命名 #"
        },
        {
          "source": "New search for #",
          "target": "搜索 #"
        },
        {
          "source": "Exclude #",
          "target": "排除 #"
        },
        {
          "source": " from search",
          "target": " 从搜索"
        },
        {
          "source": "Collapse tags at this level",
          "target": "折叠此级别的标签"
        },
        {
          "source": "Expand tags at this level",
          "target": "展开此级别的标签"
        },
        {
          "source": "Require #",
          "target": "追加 #"
        },
        {
          "source": " in search",
          "target": " 到搜索"
        },
        {
          "source": "Open tag page",
          "target": "打开标签页"
        },
        {
          "source": "This <b>cannot</b> be undone.  Do you wish to proceed?`",
          "target": "这 <b>不能</b> 撤销。  你想继续吗？`"
        },
        {
          "source": "WARNING: No Undo!,`Renaming <code>${t}</code> to <code>${n}</code> will merge ${s.canonical===t.canonical?\"these tags\":`multiple tags",
          "target": "警告: 无法撤消！,`重命名 <code>${t}</code> 到 <code>${n}</code> 将合并 ${s.canonical===t.canonical?\"这些标签\":`multiple tags"
        },
        {
          "source": "ok:\"OK\"",
          "target": "ok:\"确定\""
        },
        {
          "source": "cancel:\"Cancel\"",
          "target": "cancel:\"取消\""
        },
        {
          "source": "`Renaming #${s} (and any sub-tags)`,`Enter new name (must be a valid Obsidian tag):",
          "target": "`重命名 #${s} (以及任何子标签)`,`输入新名称 (必须是有效的Obsidian标签):"
        },
        {
          "source": ".setTitle(`Renaming #${n} (and any sub-tags)`)",
          "target": ".setTitle(`重命名 #${n} (包含子标签)`)"
        },
        {
          "source": ".setContent(`Enter new name (must be a valid Obsidian tag name)",
          "target": ".setContent(`输入新名称 (必须是有效的 Obsidian 标签名称)"
        },
        {
          "source": ".Notice(`Operation ${f.aborted?\"cancelled\":\"complete\"}: ${p} file(s) updated`)",
          "target": ".Notice(`活动 ${f.aborted?\"终止\":\"\"}: ${p} 个文件已更新`)"
        },
        {
          "source": ".onInvalidEntry(t=>new ye.Notice(`\"${t}\" is not a valid Obsidian tag name`))",
          "target": ".onInvalidEntry(t=>new ye.Notice(`\"${t}\" 不是有效的 Obsidian 标签名称`))"
        },
        {
          "source": "Notice(`Operation ${u.aborted?\"cancelled\":\"complete\"}: ${f} file(s)",
          "target": "Notice(`操作 ${u.aborted?\"取消\":\"完成\"}: ${f} file(s)"
        },
        {
          "source": "Notice(`\"${t}\" is not a valid Obsidian tag name`)",
          "target": "Notice(`\"${t}\" 不是一个有效的 Obsidian 标签名称`)"
        },
        {
          "source": ".setTitle(`Renaming #${s} (and any sub-tags)`)",
          "target": ".setTitle(`重命名 #${s}（以及所有子标签）`)"
        }
      ]
    }
  }
}