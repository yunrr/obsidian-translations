{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "table-extended",
    "version": "2.0.0",
    "title": "Table Extended",
    "description": "Enable extended table support with MultiMarkdown 6 syntax",
    "language": "zh-cn",
    "supportedVersions": "1.6.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(_line, _state.toString(16)",
          "target": ".log(_line, _state.toString(16)"
        },
        {
          "source": ".log(trToken.meta)",
          "target": ".log(trToken.meta)"
        },
        {
          "source": ".log(\"loading table-extended\")",
          "target": ".log(\"表格扩展加载中\")"
        },
        {
          "source": ".log(\"unloading table-extended\")",
          "target": ".log(\"表格扩展卸载中\")"
        },
        {
          "source": " error(type)",
          "target": " error(type)"
        },
        {
          "source": "\terror('not-basic')",
          "target": "\terror('非基本的')"
        },
        {
          "source": "\terror('invalid-input')",
          "target": "\terror('无效输入')"
        },
        {
          "source": "\terror('overflow')",
          "target": "\terror('溢出')"
        },
        {
          "source": "text: \"here\"",
          "target": "text: \"链接地址\""
        },
        {
          "source": ".setName(\"Expermental: Extended Native Table Syntax\")",
          "target": ".setName(\"实验性功能: 扩展本地Table语法\")"
        },
        {
          "source": ".setName(\"Expermental: Export to PDF support\")",
          "target": ".setName(\"实验性功能: 支持导出为PDF文件\")"
        },
        {
          "source": ".appendText(\"Use extended syntax on all native tables\")",
          "target": ".appendText(\"将扩展语法用于所有本地表格\")"
        },
        {
          "source": ".appendText(\"Some table features may be broken, if found any, please open new issue in \")",
          "target": ".appendText(\"部分表格功能上可能会存在缺失，如果发现了此类问题，请通过以下链接打开一个新的issue \")"
        },
        {
          "source": ".appendText(\"Reload obsidian to take effect\")",
          "target": ".appendText(\"重新打开Obsidian生效\")"
        },
        {
          "source": ".appendText(\"If PDF export is broken with this option enabled, disable this feature and open new issue in \")",
          "target": ".appendText(\"如果启用该功能的情况下PDF文件导出发生错误，请关闭这个功能并且通过以下链接打开一个新的issue \")"
        }
      ]
    }
  }
}