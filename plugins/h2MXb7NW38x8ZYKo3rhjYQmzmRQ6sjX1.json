        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "How much to shrink the wait time when you forget a card (e.g., 0.5 cuts it in half).",
          "target": "忘记卡片时，等待时间缩减的比例（例如，0.5 表示减半）。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "How many days until you see a new card again if you mark it \"easy\" while learning.",
          "target": "在学习阶段将卡片标记为“简单”后，再次看到新卡片的天数。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Extra time multiplier when you mark a review card \"easy\" (e.g., 1.3 adds 30% more time).",
          "target": "将复习卡片标记为“简单”时的额外时间乘数（例如，1.3 表示增加 30% 的时间）。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "The first review interval (in days) when a new card finishes its learning phase.",
          "target": "新卡片完成学习阶段后的首次复习间隔（以天为单位）。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "The lowest difficulty multiplier a card can have (prevents intervals from becoming too short).",
          "target": "卡片可具有的最低难度乘数（防止间隔变得过短）。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "How much to reduce a card's difficulty multiplier when you mark it \"again\".",
          "target": "将卡片标记为“重来”时，其难度乘数的减少量。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "The amount to adjust the difficulty multiplier. Increased when marked \"easy\", decreased when marked \"hard\". Typically 0.15.",
          "target": "调整难度乘数的量。标记为“简单”时增加，标记为“困难”时减少。通常为 0.15。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Multiplier for the next interval when you mark a card \"hard\" (e.g., 1.2 = 120% of current interval, a 20% increase). Always increases by at least 1 day.",
          "target": "将卡片标记为“困难”时，下一个间隔的乘数（例如，1.2 = 当前间隔的 120%，即增加 20%）。至少增加 1 天。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Wait times (in minutes) for reviewing new cards. E.g., \"1,10\" means review after 1 minute, then 10 minutes.",
          "target": "复习新卡片的等待时间（以分钟为单位）。例如，“1,10”表示 1 分钟后复习，然后 10 分钟后复习。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Wait times (in minutes) for reviewing forgotten cards. E.g., \"10\" means review once after 10 minutes.",
          "target": "复习遗忘卡片的等待时间（以分钟为单位）。例如，“10”表示 10 分钟后复习一次。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Delays for new cards before they enter long‑term review (e.g. \"1m,10m\"). Shorter or more steps = more initial drilling on the first day.",
          "target": "新卡片进入长期复习前的延迟（例如，“1m,10m”）。步骤更短或更多 = 第一天进行更多初始练习。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Delays for reviewing cards that you forgot while they were in review (e.g. \"10m\"). Controls how aggressively lapsed cards are re‑drilled before returning to normal scheduling.",
          "target": "复习期间遗忘卡片的延迟（例如，“10m”）。控制遗忘卡片在恢复正常调度前重新练习的强度。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Your target success rate (e.g., 0.9 = aim to remember 90% of cards). Higher = more reviews but better retention.",
          "target": "您的目标成功率（例如，0.9 = 目标记住 90% 的卡片）。越高 = 复习越多，但记忆保持越好。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "The longest you'll wait between reviews (in days), no matter how well you know a card.",
          "target": "您在复习之间等待的最长时间（以天为单位），无论您对卡片掌握得多好。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Adds slight randomness to review intervals to prevent cards from bunching up on the same days.",
          "target": "为复习间隔添加轻微随机性，以防止卡片在同一天堆积。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Enables short-term memory scheduling for cards in the learning phase (more frequent initial reviews).",
          "target": "为处于学习阶段的卡片启用短期记忆调度（更频繁的初始复习）。"
        },
