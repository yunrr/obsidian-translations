{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-copy-block-link",
    "version": "2.0.0",
    "title": "Copy Block Link",
    "description": "Get links to blocks and headings from Obsidian's right click menu",
    "language": "zh-cn",
    "supportedVersions": "1.0.4",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "(isHeading ? \"Copy link to heading\"",
          "target": "(isHeading ? \"复制标题链接\""
        },
        {
          "source": "(isHeading ? \"Copy heading embed\"",
          "target": "(isHeading ? \"复制标题嵌入\""
        },
        {
          "source": "Copy link to block",
          "target": "复制块链接"
        },
        {
          "source": "Copy block embed",
          "target": "复制块嵌入"
        },
        {
          "source": "name: \"Copy link to current block or heading\"",
          "target": "name: \"复制当前块或标题链接\""
        },
        {
          "source": "name: \"Copy embed to current block or heading\"",
          "target": "name: \"复制当前块或标题嵌入\""
        }
      ]
    }
  }
}