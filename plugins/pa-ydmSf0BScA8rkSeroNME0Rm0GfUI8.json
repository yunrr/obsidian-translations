{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "superstition",
    "version": "2.0.0",
    "title": "Superstition",
    "description": "Manage routines with traditional calendar concept of 宜/忌",
    "language": "zh-cn",
    "supportedVersions": "1.0.2",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "text: \"Today's routines\"",
          "target": "text: \"今天的例行公事\""
        },
        {
          "source": "text: \"宜 (Suitable)\"",
          "target": "text: \"☯️ 宜 (Suitable)\""
        },
        {
          "source": "text: \"忌 (Unsuitable)\"",
          "target": "text: \"👻 忌 (Unsuitable)\""
        },
        {
          "source": ".setButtonText(\"Add\")",
          "target": ".setButtonText(\"添加\")"
        },
        {
          "source": ".setButtonText(\"Delete\")",
          "target": ".setButtonText(\"删除\")"
        },
        {
          "source": ".setName(\"Add New Activity\")",
          "target": ".setName(\"添加新活动\")"
        },
        {
          "source": ".setDesc(`Period: ${this.plugin.activities[activity].period} days`)",
          "target": ".setDesc(`周期: ${this.plugin.activities[activity].period} 天一次`)"
        },
        {
          "source": ".setPlaceholder(\"Activity name\")",
          "target": ".setPlaceholder(\"活动名称\")"
        },
        {
          "source": ".setPlaceholder(\"Period (days)\")",
          "target": ".setPlaceholder(\"周期 (天)\")"
        }
      ]
    }
  }
}