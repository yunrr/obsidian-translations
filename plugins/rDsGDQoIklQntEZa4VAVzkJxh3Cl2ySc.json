{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-emoji-toolbar",
    "version": "2.0.0",
    "title": "Emoji Toolbar",
    "description": "Quickly search for and insert emojis into your notes.",
    "language": "zh-cn",
    "supportedVersions": "0.4.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setName('Twitter Emoji (v13)')",
          "target": ".setName('Twitter 表情符号（v13）')"
        },
        {
          "source": ".setDesc('Improved emoji support, but may cause unexpected behavior.')",
          "target": ".setDesc('改进了表情符号支持，但可能导致意外行为。')"
        },
        {
          "source": ".createEl('h1', { text: 'Emoji Toolbar' })",
          "target": ".createEl('h1', { text: 'Emoji Toolbar' })"
        },
        {
          "source": ".createEl('a', { text: 'Created by oliveryh', href: 'https://github.com/oliveryh/' })",
          "target": ".createEl('a', { text: '由 oliveryh创建', href: 'https://github.com/oliveryh/' })"
        },
        {
          "source": ".createEl('h2', { text: 'Settings' })",
          "target": ".createEl('h2', { text: '设置' })"
        }
      ]
    }
  }
}