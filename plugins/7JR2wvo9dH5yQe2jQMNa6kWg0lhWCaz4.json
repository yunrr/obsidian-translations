          "type": "ObjectProperty",
          "name": "text",
          "source": "Radial Timeline",
          "target": "Radial Timeline"
        },
        {
          "type": "ObjectProperty",
          "name": "text",
          "source": "Using stable note IDs",
          "target": "使用稳定的笔记ID"
