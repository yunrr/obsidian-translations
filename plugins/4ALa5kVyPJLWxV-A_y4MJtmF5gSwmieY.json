        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Descriptions longer than this will be flagged as warnings. Google typically shows about 155-160 characters of meta descriptions.",
          "target": "描述长于此长度将被标记为警告。谷歌通常会显示约155-160个字符的元描述。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "How many cards to show before the \"Load More\" button appears. Lower values load faster.",
