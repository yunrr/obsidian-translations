{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "daily-notes-editor",
    "version": "2.0.0",
    "title": "Daily Notes Editor",
    "description": "Edit a bunch of daily notes in one page(inline), which works similar to Roam Research's default daily note view.",
    "language": "zh-cn",
    "supportedVersions": "0.1.8",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(\"Failed to read the daily note template\")",
          "target": "Notice(\"读取日记模板失败\")"
        },
        {
          "source": "Notice(\"Unable to create new file.\")",
          "target": "Notice(\"无法创建新文件\")"
        },
        {
          "source": ".error(`Failed to read the daily note template '${i}'`,o)",
          "target": ".error(`读取日记模板失败 '${i}'`,o)"
        },
        {
          "source": ".error(`Failed to create file: '${u}'`,c)",
          "target": ".error(`创建文件失败: '${u}'`,c)"
        },
        {
          "source": ".error(`Failed to create file: '${l}'`,d)",
          "target": ".error(`创建文件失败: '${l}'`,d)"
        },
        {
          "source": "name:\"Open Daily Note Editor\"",
          "target": "name:\"打开每日笔记编辑器\""
        },
        {
          "source": ".setName(\"Hide frontmatter\")",
          "target": ".setName(\"隐藏frontmatter\")"
        },
        {
          "source": ".setName(\"Hide backlinks\")",
          "target": ".setName(\"隐藏反向链接\")"
        },
        {
          "source": ".setDesc(\"Hide frontmatter in daily notes\")",
          "target": ".setDesc(\"在日常笔记中隐藏正面内容\")"
        },
        {
          "source": ".setDesc(\"Hide backlinks in daily notes\")",
          "target": ".setDesc(\"在日常笔记中隐藏反向链接\")"
        },
        {
          "source": ".addRibbonIcon(\"calendar-range\",\"Open Daily Note Editor\"",
          "target": ".addRibbonIcon(\"calendar-range\",\"打开日记流\""
        },
        {
          "source": "return\"Daily Note\"",
          "target": "return\"日记流编辑器\""
        },
        {
          "source": "t.innerHTML='<div class=\"dn-blank-day-text svelte-16g9gs\">Create a daily note for today ✍</div>'",
          "target": "t.innerHTML='点此创建今天的笔记 ✍'"
        },
        {
          "source": "t.textContent=\"—— No more of results ——\",",
          "target": "t.textContent=\"—— 这是我的底线了 ——\","
        }
      ]
    }
  }
}