{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-latex-environments",
    "version": "2.0.0",
    "title": "Latex Environments",
    "description": "Allows to quickly insert and change latex environments within math environments.",
    "language": "zh-cn",
    "supportedVersions": "0.4.2",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "name: \"Insert LaTeX environment\"",
          "target": "name: \"插入LaTeX环境\""
        },
        {
          "source": "name: \"Change LaTeX environment\"",
          "target": "name: \"修改LaTeX环境\""
        },
        {
          "source": "name: \"Delete LaTeX environment\"",
          "target": "name: \"删除LaTeX环境\""
        },
        {
          "source": ".setName(\"Default environment\")",
          "target": ".setName(\"默认环境\")"
        },
        {
          "source": ".setName(\"Extra environments\")",
          "target": ".setName(\"额外的环境\")"
        },
        {
          "source": ".setDesc(\"The default environment to insert\")",
          "target": ".setDesc(\"插入的默认环境\")"
        },
        {
          "source": ".setDesc(\"Environment names to be suggested for completion (one per line)\")",
          "target": ".setDesc(\"待补全的环境名称（每行一个）\")"
        },
        {
          "source": ".setPlaceholder(\"environment name\")",
          "target": ".setPlaceholder(\"环境名称\")"
        },
        {
          "source": ".setPlaceholder(\"environment\")",
          "target": ".setPlaceholder(\"环境\")"
        }
      ]
    }
  }
}