{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-trash-explorer",
    "version": "2.0.0",
    "title": "Trash Explorer",
    "description": "Restore and delete files from the Obsidian .trash folder",
    "language": "zh-cn",
    "supportedVersions": "1.2.3",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(`Restored \"${item.basename}\" from trash`)",
          "target": "Notice(`已从回收站还原\"${item.basename}\"`)"
        },
        {
          "source": "Notice(\n      `Unable to restore \"${item.basename}\": the path already exists`,\n      10 * 1e3\n    )",
          "target": "Notice(\n      `无法还原\"${item.basename}\"：路径已存在`,\n      10 * 1e3\n    )"
        },
        {
          "source": "Notice(`Permanently deleted \"${item.basename}\"`)",
          "target": "Notice(`已永久删除\"${item.basename}\"`)"
        },
        {
          "source": "Notice(`Emptied the trash`)",
          "target": "Notice(`清空垃圾`)"
        },
        {
          "source": "name: \"Show trash explorer\"",
          "target": "name: \"显示垃圾资源管理器\""
        },
        {
          "source": "name: \"Empty trash\"",
          "target": "name: \"清空垃圾\""
        },
        {
          "source": ".setButtonText(\"Cancel\")",
          "target": ".setButtonText(\"取消\")"
        },
        {
          "source": "\"Filter by name...\"",
          "target": "\"按名称筛选……\""
        },
        {
          "source": "`Are you sure you want to permanently delete \"${item.basename}\"?`",
          "target": "`您确定要永久删除\"${item.basename}\"吗？`"
        },
        {
          "source": "\"Delete\"",
          "target": "\"删除\""
        },
        {
          "source": "\"Delete file\"",
          "target": "\"删除文件\""
        },
        {
          "source": "\"Filter matched no files.\"",
          "target": "\"筛选器未匹配到任何文件。\""
        },
        {
          "source": "title = \"Empty trash\"",
          "target": "title = \"清空回收站\""
        },
        {
          "source": "\"Empty trash\"",
          "target": "\"清空回收站\""
        },
        {
          "source": "message = `Are you sure you want to empty the trash? All files in the \"${TRASH_ROOT}\" folder will be permanently deleted!`",
          "target": "message = `你确定要清空回收站吗？ \"${TRASH_ROOT}\" 文件夹中的所有文件将被永久删除！`"
        },
        {
          "source": "\"Open trash explorer\"",
          "target": "\"打开回收站\""
        },
        {
          "source": "attr(button0, \"aria-label\", \"Restore\");",
          "target": "attr(button0, \"aria-label\", \"恢复\");"
        },
        {
          "source": "attr(button1, \"aria-label\", \"Delete permanently\");",
          "target": "attr(button1, \"aria-label\", \"永久删除\");"
        },
        {
          "source": "\"The trash is empty.\"",
          "target": "\"回收站是空的。\""
        }
      ]
    }
  }
}