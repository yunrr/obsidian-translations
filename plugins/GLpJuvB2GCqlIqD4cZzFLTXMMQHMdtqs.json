{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "listen-up",
    "version": "2.0.0",
    "title": "Listen Up!",
    "description": "Covert text to natural voice audio, locally - Listen Up!",
    "language": "zh-cn",
    "supportedVersions": "1.0.7",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(\n          \"Converting the text to natural speech, please wait..\",\n          0\n        )",
          "target": "Notice(\n          \"正在将文本转换为自然语音，请稍候..\",\n          0\n        )"
        },
        {
          "source": "alog({\n          properties: [\"openFile\"],\n          title: \"Select a model\"\n        })",
          "target": "alog({\n          properties: [\"openFile\"],\n          title: \"选择模型\"\n        })"
        },
        {
          "source": "alog({\n          properties: [\"openFile\"],\n          title: \"Select a model config\"\n        })",
          "target": "alog({\n          properties: [\"openFile\"],\n          title: \"选择模型配置\"\n        })"
        },
        {
          "source": "alog({\n          properties: [\"openFile\"],\n          title: \"Select piper executable\"\n        })",
          "target": "alog({\n          properties: [\"openFile\"],\n          title: \"选择Piper可执行文件\"\n        })"
        },
        {
          "source": ".error(e)",
          "target": ".error(e)"
        },
        {
          "source": ".error(`\n\nerror: ${error.message}`)",
          "target": ".error(`\n\n错误: ${error.message}`)"
        },
        {
          "source": "name: \"Convert text to speech\"",
          "target": "name: \"文本转语音\""
        },
        {
          "source": ".setName(\"Select custom model file\")",
          "target": ".setName(\"选择自定义模型文件\")"
        },
        {
          "source": ".setName(\"Select model config file\")",
          "target": ".setName(\"选择模型配置文件\")"
        },
        {
          "source": ".setName(\"Use custom model?\")",
          "target": ".setName(\"使用自定义模型吗?\")"
        },
        {
          "source": ".setName(\"Select Piper executable file\")",
          "target": ".setName(\"选择Piper可执行文件\")"
        },
        {
          "source": ".setDesc(`File that ends with .onnx`)",
          "target": ".setDesc(`以 .onnx 结尾的文件`)"
        },
        {
          "source": ".setDesc(`File that ends with .json`)",
          "target": ".setDesc(`以 .json 结尾的文件`)"
        },
        {
          "source": ".setDesc(`Turn this on if you want to use different voice model. Check this doc to understand more: DOC LINK`)",
          "target": ".setDesc(`如果您想使用不同的语音模型，请打开此选项。请查看此文档以了解更多信息: DOC LINK`)"
        },
        {
          "source": ".setDesc(`This is required`)",
          "target": ".setDesc(`这是必需的`)"
        },
        {
          "source": ".setTooltip(\"Select model\")",
          "target": ".setTooltip(\"选择模型\")"
        },
        {
          "source": ".setTooltip(\"Select model config\")",
          "target": ".setTooltip(\"选择模型配置\")"
        },
        {
          "source": ".setTooltip(\"Select piper executable\")",
          "target": ".setTooltip(\"选择Piper可执行文件\")"
        }
      ]
    }
  }
}