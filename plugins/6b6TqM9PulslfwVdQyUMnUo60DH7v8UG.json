        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Master switch for all AI features.",
          "target": "所有AI功能的主开关。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Custom prompt. The video metadata block is still added automatically.",
          "target": "自定义提示词。视频元数据块仍会自动添加。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Add a TL;DR section in a summary callout.",
          "target": "在摘要标注框中添加TL;DR部分。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Embed the YouTube video, playlist video, thumbnail, or no media near the top of the note.",
          "target": "在笔记顶部附近嵌入YouTube视频、播放列表视频、缩略图或不嵌入媒体。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Rename the destination note to the video or playlist title. Not applicable for multiple videos in one note.",
          "target": "将目标笔记重命名为视频或播放列表标题。不适用于一个笔记中的多个视频。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Add a YAML frontmatter block. Useful for note properties, Dataview, and search.",
          "target": "添加YAML前置元数据块。适用于笔记属性、Dataview和搜索。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Comma- or space-separated tags added to the frontmatter. Example: YouTube, AI/summary.",
          "target": "添加到前置元数据的逗号或空格分隔的标签。示例：YouTube, AI/summary。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Space- or comma-separated list. Allowed keys: title, aliases, source, channel, channelUrl, channelId, videoUrl, playlistUrl, videoId, playlistId, thumbnailUrl, videoDescription, uploadDate, videoCategory, durationSeconds, keywords, generated, videoCount.",
          "target": "空格或逗号分隔的列表。允许的键：title, aliases, source, channel, channelUrl, channelId, videoUrl, playlistUrl, videoId, playlistId, thumbnailUrl, videoDescription, uploadDate, videoCategory, durationSeconds, keywords, generated, videoCount。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Render the source block (title, channel, URL) at top or bottom.",
          "target": "在顶部或底部渲染源块（标题、频道、URL）。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Use the current note, append to the active note, or create notes in a folder.",
          "target": "使用当前笔记、追加到活动笔记，或在文件夹中创建笔记。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Created automatically if it does not exist.",
          "target": "如果不存在则自动创建。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "How transcript content appears in the generated note.",
          "target": "转录内容在生成的笔记中的显示方式。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "When using the timestamped transcript, deep-link to the video at that time.",
          "target": "使用带时间戳的转录时，深度链接到该时间点的视频。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Auto picks any available transcript. Preferred tries your language first, then falls back.",
          "target": "自动选择任何可用的转录。首选先尝试您的语言，然后回退。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Used when transcript language is set to preferred. Example: en, fr, ar.",
          "target": "当转录语言设置为首选时使用。示例：en, fr, ar。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Create a single combined note for the whole playlist, or one note per video.",
          "target": "为整个播放列表创建一个合并的笔记，或为每个视频创建一个笔记。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
          "source": "Skip the video with a missing transcript, or stop the entire run.",
          "target": "跳过缺少转录的视频，或停止整个运行。"
        },
        {
          "type": "ObjectProperty",
          "name": "desc",
