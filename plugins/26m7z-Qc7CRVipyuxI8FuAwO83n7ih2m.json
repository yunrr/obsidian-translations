{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-full-calendar",
    "version": "2.0.0",
    "title": "Full Calendar",
    "description": "Obsidian integration with Full Calendar (fullcalendar.io)",
    "language": "zh-cn",
    "supportedVersions": "0.10.7",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setName(\"Calendars\")",
          "target": ".setName(\"日历\")"
        },
        {
          "source": ".setName(\"Desktop Initial View\")",
          "target": ".setName(\"桌面初始视图\")"
        },
        {
          "source": ".setName(\"Mobile Initial View\")",
          "target": ".setName(\"移动设备初始视图\")"
        },
        {
          "source": ".setName(\"Starting Day of the Week\")",
          "target": ".setName(\"一周的起始日\")"
        },
        {
          "source": ".setName(\"24-hour format\")",
          "target": ".setName(\"24小时制\")"
        },
        {
          "source": ".setDesc(\"Add calendar\")",
          "target": ".setDesc(\"添加日历\")"
        },
        {
          "source": ".setDesc(\"Choose the initial view range on desktop devices.\")",
          "target": ".setDesc(\"选择桌面设备上的初始视图范围。\")"
        },
        {
          "source": ".setDesc(\"Choose the initial view range on mobile devices.\")",
          "target": ".setDesc(\"选择移动设备上的初始视图范围。\")"
        },
        {
          "source": ".setDesc(\"Choose what day of the week to start.\")",
          "target": ".setDesc(\"选择一周的起始日。\")"
        },
        {
          "source": ".setDesc(\"Display the time in a 24-hour format.\")",
          "target": ".setDesc(\"以24小时制显示时间。\")"
        },
        {
          "source": ".setTooltip(\"Add Calendar\")",
          "target": ".setTooltip(\"添加日历\")"
        },
        {
          "source": ".createEl(\"h2\", { text: \"Calendar Preferences\" })",
          "target": ".createEl(\"h2\", { text: \"日历偏好设置\" })"
        },
        {
          "source": ".createEl(\"h2\", { text: \"Manage Calendars\" })",
          "target": ".createEl(\"h2\", { text: \"管理日历\" })"
        }
      ]
    }
  }
}