        {
          "source": "text: \"Name\"",
          "target": "text: \"名称\""
        },
        {
          "source": "text: \"Style\"",
          "target": "text: \"样式\""
        },
        {
          "source": "text: \"Add Style\"",
          "target": "text: \"添加样式\""
        },
        {
          "source": "text: \"Usage with the Command Palette:\"",
          "target": "text: \"与命令面板的使用：\""
        },
        {
          "source": "text: \"Select text on the editor\"",
          "target": "text: \"在编辑器中选择文本\""
        },
        {
          "source": "text: \"Open the Command Palette: <Ctrl> or <Cmd> + <P>\"",
          "target": "text: \"打开命令面板：或 +\""
        },
        {
          "source": "text: 'Look up the Style to apply: \"Style Text ...\"'",
          "target": "text: '查找要应用的样式: \"样式文本 ...\"'"
        },
        {
          "source": "text: \"Choose the Style: <Enter>\"",
          "target": "text: \"选择样式： \""
        },
        {
          "source": "text: \"Remove Applied Styles:\"",
          "target": "text: \"移除已应用的样式：\""
        },
        {
          "source": "text: \"Select the styled text on the editor\"",
          "target": "text: \"在编辑器中选择已样式化的文本\""
        },
        {
          "source": "text: 'Look up: \"Style Remove\"'",
          "target": "text: '查找: \"样式移除\"'"
        },
        {
          "source": "text: \"Press <Enter>\"",
          "target": "text: \"按下 \""
        },
        {
          "source": ".setTooltip(\"Move up\")",
          "target": ".setTooltip(\"向上移动\")"
        },
        {
          "source": ".setTooltip(\"Move down\")",
          "target": ".setTooltip(\"向下移动\")"
        },
        {
          "source": ".setTooltip(\"Remove Style\")",
          "target": ".setTooltip(\"移除样式\")"
        },
        {
          "source": ".setTitle(\"Remove Style\")",
          "target": ".setTitle(\"移除样式\")"
        }
