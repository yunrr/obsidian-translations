{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "link-preview",
    "version": "2.0.0",
    "title": "Link Preview",
    "description": "Show a preview of external links on hover",
    "language": "zh-cn",
    "supportedVersions": "0.1.3",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setText(\"Loading preview...\")",
          "target": ".setText(\"正在加载预览...\")"
        },
        {
          "source": ".setText(\"Failed to load preview\")",
          "target": ".setText(\"加载预览失败\")"
        },
        {
          "source": ".setName(\"Preview delay\")",
          "target": ".setName(\"预览延迟\")"
        },
        {
          "source": ".setName(\"Maximum preview height\")",
          "target": ".setName(\"最大预览高度\")"
        },
        {
          "source": ".setName(\"Maximum preview width\")",
          "target": ".setName(\"最大预览宽度\")"
        },
        {
          "source": ".setDesc(\"How long to wait before showing the preview (in milliseconds)\")",
          "target": ".setDesc(\"在显示预览前等待的时间(毫秒)\")"
        },
        {
          "source": ".setDesc(\"Maximum height of the preview window (in pixels)\")",
          "target": ".setDesc(\"预览窗口的最大高度(像素)\")"
        },
        {
          "source": ".setDesc(\"Maximum width of the preview window (in pixels)\")",
          "target": ".setDesc(\"预览窗口的最大宽度(像素)\")"
        }
      ]
