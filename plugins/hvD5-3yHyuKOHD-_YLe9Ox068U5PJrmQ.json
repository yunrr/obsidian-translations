        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "No inflection rules. Build your own from scratch.",
          "target": "无屈折规则。从头开始构建您自己的规则。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Just plural and past tense. Good for 'flavour' conlangs where the language only appears in names and short phrases.",
          "target": "仅复数和过去时。适用于“风味”人造语言，其中语言仅出现在名称和短语中。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Plural, past tense, present participle, possessive, comparative. Covers the common cases for English/Spanish/German-flavoured conlangs.",
          "target": "复数、过去时、现在分词、所有格、比较级。涵盖英语/西班牙语/德语风味人造语言的常见情况。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Adds 3rd-person singular, past participle, superlative, and agent noun derivation. A serious starter kit.",
          "target": "添加第三人称单数、过去分词、最高级和施事者名词派生。一个严肃的入门套件。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Case markers (nominative/accusative/genitive/dative/locative) and tense markers. Inspired by Finnish/Turkish/Quenya-style languages where each grammatical role gets its own suffix.",
          "target": "格标记（主格/宾格/属格/与格/方位格）和时态标记。灵感来自芬兰语/土耳其语/昆雅语风格的语言，其中每个语法角色都有自己的后缀。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "No inflection rules — the language uses word order and particles for grammar. Pick this for Mandarin/Vietnamese-flavoured conlangs, or any language where 'grammar happens between words, not inside them'.",
          "target": "无屈折规则——该语言使用语序和助词进行语法表达。选择此选项适用于普通话/越南语风味的人造语言，或任何“语法发生在词间，而非词内”的语言。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "A person, place, thing, or idea. e.g. cat, river, freedom.",
          "target": "一个人、地点、事物或想法。例如：猫、河流、自由。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "An action or state of being. e.g. run, become, exist.",
          "target": "一个动作或存在状态。例如：跑、成为、存在。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Describes a noun. e.g. red, tall, ancient.",
          "target": "描述名词。例如：红色的、高的、古老的。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Describes a verb, adjective, or other adverb — usually how, when, where. e.g. quickly, often, here.",
          "target": "描述动词、形容词或其他副词——通常是方式、时间、地点。例如：快速地、经常、这里。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Stands in for a noun. e.g. she, they, it, this.",
          "target": "代替名词。例如：她、他们、它、这个。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "A specific name. Capitalised in English. e.g. Alice, London, Mars.",
          "target": "一个特定的名称。在英语中大写。例如：爱丽丝、伦敦、火星。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Shows a relationship between words — usually spatial, temporal, or logical. e.g. in, on, before, with.",
          "target": "显示词语之间的关系——通常是空间、时间或逻辑关系。例如：在……里、在……上、在……之前、和……一起。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Joins words, phrases, or clauses. e.g. and, but, because.",
          "target": "连接单词、短语或从句。例如：和、但是、因为。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "An exclamation expressing emotion or reaction. e.g. oh!, wow, alas.",
          "target": "表达情感或反应的感叹词。例如：哦！、哇、唉。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "A person — protagonist, antagonist, supporting figure. Includes the names of gods and personified forces.",
          "target": "一个人——主角、反派、配角。包括神和拟人化力量的名字。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "A geographic location — city, region, mountain, river, building. Anything with coordinates in your world.",
          "target": "一个地理位置——城市、地区、山脉、河流、建筑物。任何在您的世界中有坐标的东西。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "An organised group — kingdom, guild, religion, conspiracy, military unit. Things that have agency but aren't individuals.",
          "target": "一个有组织的群体——王国、公会、宗教、阴谋、军事单位。具有能动性但不是个体的事物。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "A unique object — a named sword, a specific tome, a relic. Common-noun objects (like 'a sword') aren't names.",
          "target": "一个独特的物品——一把有名字的剑、一本特定的书、一件遗物。普通名词物品（如“一把剑”）不是名称。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "A specific historical event — battle, treaty, disaster. 'The Burning Year', not 'a fire'.",
          "target": "一个特定的历史事件——战役、条约、灾难。“燃烧之年”，而不是“一场火”。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "A specific role or rank that's treated as a proper noun — 'the High King', 'the Dawnspeaker'. Often capitalised in prose.",
          "target": "一个被视为专有名词的特定角色或头衔——“至高王”、“黎明语者”。在散文中通常大写。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Anything else that gets its own proper-noun treatment.",
          "target": "任何其他获得专有名词待遇的事物。"
        },
        {
          "type": "ObjectProperty",
          "name": "description",
          "source": "Describes a verb, adjective, or other adverb. e.g. quickly, often, here.",
          "target": "描述动词、形容词或其他副词。例如：快速地、经常、这里。"
        },
        {
          "type": "ObjectProperty",
