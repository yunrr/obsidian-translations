{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "code-language-completer",
    "version": "2.0.0",
    "title": "Code Language Completer",
    "description": "Autosuggests and completes codeblock language options based on history.",
    "language": "zh-cn",
    "supportedVersions": "1.0.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "name: \"Insert code block\"",
          "target": "name: \"插入代码块\""
        },
        {
          "source": ".setButtonText(\"Reset\")",
          "target": ".setButtonText(\"重置\")"
        },
        {
          "source": ".setName(\"Last used language\")",
          "target": ".setName(\"上次使用的语言\")"
        },
        {
          "source": ".setName(\"Additional languages\")",
          "target": ".setName(\"其他语言\")"
        },
        {
          "source": ".setName(\"Reset last used language\")",
          "target": ".setName(\"重置上次使用的语言\")"
        },
        {
          "source": ".setDesc(\"The last programming language you used in a code block.\")",
          "target": ".setDesc(\"您在代码块中上次使用的编程语言。\")"
        },
        {
          "source": ".setDesc(\"Add more languages (comma-separated).\")",
          "target": ".setDesc(\"添加更多语言（以逗号分隔）。\")"
        },
        {
          "source": ".setDesc(\"Clear the last used language.\")",
          "target": ".setDesc(\"清除上次使用的语言记录。\")"
        },
        {
          "source": ".setPlaceholder(\"No language selected yet\")",
          "target": ".setPlaceholder(\"尚未选择语言\")"
        },
        {
          "source": ".setPlaceholder(\"e.g., ruby, lang1, lang2\")",
          "target": ".setPlaceholder(\"例如：ruby, lang1, lang2\")"
        }
      ]
    }
  }
}