{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-remember-file-state",
    "version": "2.0.0",
    "title": "Remember File State",
    "description": "Remembers cursor position, selection, scrolling, and more for each file",
    "language": "zh-cn",
    "supportedVersions": "1.1.2",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(\"RememberFileState: loading plugin\")",
          "target": ".log(\"RememberFileState: 加载插件\")"
        },
        {
          "source": ".error(\"RememberFileState: couldn't restore file state: \", err)",
          "target": ".error(\"RememberFileState:无法还原文件状态：\", err)"
        },
        {
          "source": ".setName(\"Remember files\")",
          "target": ".setName(\"文件记忆数量\")"
        },
        {
          "source": ".setName(\"Save states\")",
          "target": ".setName(\"保存状态\")"
        },
        {
          "source": ".setDesc(\"How many files to remember at most\")",
          "target": ".setDesc(\"最多要记住多少个文件\")"
        },
        {
          "source": ".setDesc(\"Whether to save the state of all open files to disk\")",
          "target": ".setDesc(\"是否将所有打开文件的状态保存到磁盘\")"
        }
      ]
    }
  }
}