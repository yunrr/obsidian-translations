          "target": "Notice(\"Searching for unused block IDs...\", 0)"
        },
        {
          "source": "Notice(\"No unused block IDs found.\")",
          "target": "Notice(\"No unused block IDs found.\")"
        },
        {
          "source": "Notice(`Error: ${error.message}`)",
