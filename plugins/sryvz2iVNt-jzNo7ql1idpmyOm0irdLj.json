{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "etymology-lookup",
    "version": "1.0.0",
    "title": "Etymology Lookup",
    "description": "Etymology Lookup Localization & Tweaks",
    "language": "zh-cn",
    "supportedVersions": "2.0.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [
        {
          "type": "AssignmentExpression",
          "name": "innerText",
          "source": "Online Etymology Dictionary",
          "target": "在线词源词典"
        },
        {
          "type": "CallExpression",
          "name": "appendText",
          "source": "Results from ",
          "target": "结果来自 "
        },
        {
          "type": "CallExpression",
          "name": "log",
          "source": "loading Etymology Lookup plugin",
          "target": "正在加载词源查找插件"
        },
        {
          "type": "CallExpression",
          "name": "setText",
          "source": "No etymology results found.",
          "target": "未找到词源结果。"
        },
        {
          "type": "CallExpression",
          "name": "setText",
          "source": "Search failed. Are you connected to the internet?",
          "target": "搜索失败。您是否已连接到互联网？"
        },
        {
          "type": "CallExpression",
          "name": "setText",
          "source": "Highlight a word in your notes to search its etymology!",
          "target": "在您的笔记中高亮一个单词以搜索其词源！"
        },
        {
          "type": "NewExpression",
          "name": "Notice",
          "source": "Copied!",
          "target": "已复制！"
        },
        {
          "type": "NewExpression",
          "name": "Notice",
          "source": "Failed to copy :(",
          "target": "复制失败 :("
        },
        {
          "type": "ObjectProperty",
          "name": "header",
          "source": ":is(h1, h2, h3, h4, h5, h6)",
          "target": ":is(h1, h2, h3, h4, h5, h6)"
        },
        {
          "type": "ObjectProperty",
          "name": "name",
          "source": "Search",
          "target": "搜索"
        },
        {
          "type": "ObjectProperty",
          "name": "text",
          "source": "input:is(:not([type!='']), [type=text])",
          "target": "input:is(:not([type!='']), [type=text])"
        }
      ],
      "regex": []
    }
  }
}