{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "immersive-translate",
    "version": "2.0.0",
    "title": "Immersive Translate",
    "description": "Translate plugin setting page.",
    "language": "zh-cn",
    "supportedVersions": "0.0.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setButtonText(\"relaunch\")",
          "target": ".setButtonText(\"重新启动\")"
        },
        {
          "source": ".setName(\"Relaunch\")",
          "target": ".setName(\"重新启动\")"
        },
        {
          "source": ".setName(\"\").setDesc(\"\")",
          "target": ".setName(\"\").setDesc(\"\")"
        },
        {
          "source": ".setName(\"Selectors\")",
          "target": ".setName(\"选择器\")"
        },
        {
          "source": ".setName(\"ExcludeSelectors\")",
          "target": ".setName(\"排除选择器\")"
        },
        {
          "source": ".setDesc(\"settings is changed, it need to relaunch\")",
          "target": ".setDesc(\"设置已更改，需要重新启动\")"
        },
        {
          "source": ".setDesc(`Array, default: ${g(i)}`)",
          "target": ".setDesc(`数组，默认：${g(i)}`)"
        },
        {
          "source": ".setDesc(`Array, default: ${g(a)}`)",
          "target": ".setDesc(`数组，默认： ${g(a)}`)"
        }
      ]
    }
  }
}