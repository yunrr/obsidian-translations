{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "markdown-table-editor",
    "version": "2.0.0",
    "title": "Markdown Table Editor",
    "description": "An Obsidian plugin to provide an editor for Markdown tables. It can open CSV, Microsoft Excel/Google Sheets data as Markdown tables from Obsidian Markdown editor.",
    "language": "zh-cn",
    "supportedVersions": "0.3.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setName(\"Default Direction\")",
          "target": ".setName(\"默认方向\")"
        },
        {
          "source": ".setName(\"Number of rows\")",
          "target": ".setName(\"行数\")"
        },
        {
          "source": ".setName(\"Number of columns\")",
          "target": ".setName(\"列数\")"
        },
        {
          "source": ".setDesc(\"Default direction in which the Markdown Editor has to be opened\")",
          "target": ".setDesc(\"Markdown编辑器打开的默认方向\")"
        },
        {
          "source": ".setDesc(\"Default number of rows in new tables created\")",
          "target": ".setDesc(\"创建的新表中的默认行数\")"
        },
        {
          "source": ".setDesc(\"Default number of columns in new tables created\")",
          "target": ".setDesc(\"创建的新表中的默认列数\")"
        },
        {
          "source": ".createEl(\"h2\", { text: \"Settings for Markdown Table Editor\" })",
          "target": ".createEl(\"h2\", { text: \"Markdown表格编辑器的设置\" })"
        },
        {
          "source": ".addRibbonIcon(\"spreadsheet\", \"Open Markdown Table Editor\"",
          "target": ".addRibbonIcon(\"spreadsheet\", \"打开Markdown表格编辑器\""
        },
        {
          "source": ".useState(\"Copy as Markdown\")",
          "target": ".useState(\"复制为Markdown\")"
        },
        {
          "source": ".addOption(\"vertical\", \"Open to the right of active editor\")",
          "target": ".addOption(\"vertical\", \"在活动编辑器的右侧打开\")"
        },
        {
          "source": ".addOption(\"horizontal\", \"Open below the active editor\")",
          "target": ".addOption(\"horizontal\", \"在活动编辑器下方打开\")"
        },
        {
          "source": ".addOption(\"popover\", \"Open in popover\")",
          "target": ".addOption(\"popover\", \"在popover中打开\")"
        },
        {
          "source": "setCopyText(\"Copy as Markdown\")",
          "target": "setCopyText(\"复制为 Markdown\")"
        },
        {
          "source": "setCopyText(\"Copied!\")",
          "target": "setCopyText(\"复件!\")"
        },
        {
          "source": ", \"Update Table\")",
          "target": ", \"更新表格\")"
        },
        {
          "source": ".setTitle(\"Left align\"",
          "target": ".setTitle(\"左对齐\""
        },
        {
          "source": ".setTitle(\"Center align\"",
          "target": ".setTitle(\"中心对齐\""
        },
        {
          "source": ".setTitle(\"Right align\"",
          "target": ".setTitle(\"右对齐\""
        },
        {
          "source": ".setTitle(\"Sort text ascending\"",
          "target": ".setTitle(\"文本升序排序\""
        },
        {
          "source": ".setTitle(\"Sort text descending\"",
          "target": ".setTitle(\"文本降序排序\""
        },
        {
          "source": ".setTitle(\"Sort numeric ascending\"",
          "target": ".setTitle(\"按数字升序排序\""
        },
        {
          "source": ".setTitle(\"Sort numeric descending\"",
          "target": ".setTitle(\"按数字降序排序\""
        },
        {
          "source": ".setTitle(\"Add row above\"",
          "target": ".setTitle(\"在上面添加行\""
        },
        {
          "source": ".setTitle(\"Add row below\"",
          "target": ".setTitle(\"在下面添加行\""
        },
        {
