          "target": ".setTitle(\"删除行\""
        },
        {
          "source": ".setTitle(\"Add column left\"",
          "target": ".setTitle(\"添加左侧列\""
        },
        {
          "source": ".setTitle(\"Add column right\"",
          "target": ".setTitle(\"向右添加列\""
        },
        {
          "source": ".setTitle(\"Remove column\"",
          "target": ".setTitle(\"删除列\""
        },
        {
          "source": ".setTitle(\"Move row up\"",
          "target": ".setTitle(\"向上移动行\""
        },
        {
          "source": ".setTitle(\"Move row down\"",
          "target": ".setTitle(\"向下移动行\""
        },
        {
          "source": ".setTitle(\"Move column right\"",
          "target": ".setTitle(\"将列向右移动\""
        },
        {
          "source": ".setTitle(\"Move column left\"",
          "target": ".setTitle(\"将列向左移动\""
        },
        {
          "source": ".setTitle(\"Cut\"",
          "target": ".setTitle(\"剪切\""
        },
        {
          "source": ".setTitle(\"Copy\"",
          "target": ".setTitle(\"复制\""
        },
        {
          "source": ".setTitle(\"Paste\"",
          "target": ".setTitle(\"粘贴\""
        },
        {
          "source": ".Notice(\"Can not move this row up!\"",
          "target": ".Notice(\"不能将本行向上移动！\""
        },
        {
          "source": ".Notice(\"Can not move this row down!\"",
          "target": ".Notice(\"不能将本行向下移动！\""
        },
        {
          "source": ".Notice(\"Can not move this column right!\"",
          "target": ".Notice(\"不能向右移动此列！\""
        },
        {
          "source": ".Notice(\"Can not move this column left!\"",
          "target": ".Notice(\"不能向左移动此列！\""
        },
        {
          "source": ".Notice(\"Selection is not a valid Markdown table or CSV or Excel data. Creating a new table!\"",
          "target": ".Notice(\"选择不是有效的 Markdown 、CSV 表或 Excel 数据。请创建一个新表！\""
        },
        {
          "source": "return \"Markdown Table Editor\"",
          "target": "return \"Markdown表格编辑器\""
        },
        {
          "source": ", \"New Table\"",
          "target": ", \"新表\""
        },
        {
          "source": ", \"Clear Table\"",
          "target": ", \"清除表格\""
        }
      ]
    }
