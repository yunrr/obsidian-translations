  "metadata": {
    "plugin": "refresh-preview",
    "version": "2.0.0",
    "title": "Refresh Any View",
    "description": "Allows to refresh preview mode without reopening the note",
    "language": "zh-cn",
    "supportedVersions": "2.0.16",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(\"An unhandled error occurred. Please check the console for more information.\")",
          "target": "Notice(\"发生未处理的错误。请检查控制台以了解更多信息。\")"
        },
        {
          "source": "Notice(r)",
          "target": "Notice(r)"
        },
        {
