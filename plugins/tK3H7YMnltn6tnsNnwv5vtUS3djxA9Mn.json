          "target": ".error(`Module not found: ${id}. Fake process object is returned instead.`)"
        },
        {
          "source": ".error(`Module not found: ${id}. Empty object is returned instead.`)",
          "target": ".error(`Module not found: ${id}. Empty object is returned instead.`)"
        },
        {
          "source": ".error(`\\x1B[0m${l.message}\\x1B[0m`)",
          "target": ".error(`\\x1B[0m${l.message}\\x1B[0m`)"
        },
        {
          "source": ".error(l.message)",
          "target": ".error(l.message)"
        },
        {
          "source": ".error(`Invalid data type. Expected Object, got: ${h}`)",
          "target": ".error(`Invalid data type. Expected Object, got: ${h}`)"
        },
        {
          "source": ".error(\"Validation failed\",{propertyName:this.propertyName,value:this._currentValue},r)",
          "target": ".error(\"Validation failed\",{propertyName:this.propertyName,value:this._currentValue},r)"
        },
        {
          "source": "name:\"\"};if(r.length===0)return i;var l=r.charCodeAt(0),c=l===47,f;c?(i.root=\"",
          "target": "name:\"\"};if(r.length===0)return i;var l=r.charCodeAt(0),c=l===47,f;c?(i.root=\""
