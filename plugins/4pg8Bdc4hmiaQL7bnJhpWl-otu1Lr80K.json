{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "pomodoro-widget",
    "version": "2.0.0",
    "title": "Pomodoro Widget",
    "description": "Provides a widget based on a pomodoro kitchen timer. It's designed to be haptic, and has a constant ticking sound, and an alarm sound that can be toggled.",
    "language": "zh-cn",
    "supportedVersions": "1.0.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(this.settings.timerToggleLocation)",
          "target": ".log(this.settings.timerToggleLocation)"
        },
        {
          "source": "name: \"Toggle timer / stopwatch\"",
          "target": "name: \"切换计时器/秒表\""
        },
        {
          "source": ".setButtonText(\"Reset widget\")",
          "target": ".setButtonText(\"重置小部件\")"
        },
        {
          "source": ".setName(\"Default timer time\")",
          "target": ".setName(\"默认定时器时间\")"
        },
        {
          "source": ".setName(\"Ticking enabled\")",
          "target": ".setName(\"启用勾选\")"
        },
        {
          "source": ".setName(\"Ticking volume\")",
          "target": ".setName(\"滴答音量\")"
        },
        {
          "source": ".setName(\"Ticking speed\")",
          "target": ".setName(\"滴答速度\")"
        },
        {
          "source": ".setName(\"Alarm volume\")",
          "target": ".setName(\"闹钟音量\")"
        },
        {
          "source": ".setName(\"Widget toggle location\")",
          "target": ".setName(\"小部件切换位置\")"
        },
        {
          "source": ".setName(\"Reset widget position and anchor\")",
          "target": ".setName(\"重置小部件位置和锚点\")"
        },
        {
          "source": ".setDesc(\"The initial value of the timer, and the value the timer resets to after ringing.\")",
          "target": ".setDesc(\"定时器的初始值，以及振铃后定时器重置的值。\")"
        },
        {
          "source": ".innerText = `25:00`",
          "target": ".innerText = `25:00`"
        },
        {
          "source": ".innerText = \"00:00:00\"",
          "target": ".innerText = \"00:00:00\""
        },
        {
          "source": ".innerText = \"SET\"",
          "target": ".innerText = \"设置\""
        }
      ]
    }
  }
}