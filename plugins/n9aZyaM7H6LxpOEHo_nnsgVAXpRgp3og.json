{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-heading-shifter",
    "version": "2.0.0",
    "title": "Heading Shifter",
    "description": "Easily Shift and Change markdown headings.",
    "language": "zh-cn",
    "supportedVersions": "1.7.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(\"Cannot Increase (contains more than Heading 6)",
          "target": "Notice(\"无法增加（包含超过标题 6）"
        },
        {
          "source": "Notice(`Cannot Decrease (contains less than Heading${Number(this.settings.limitHeadingFrom)",
          "target": "Notice(`无法减少（包含少于标题${Number(this.settings.limitHeadingFrom)"
        },
        {
          "source": ".error(error)",
          "target": ".error(error)"
        },
        {
          "source": "name: `Apply Heading ${this.headingSize}`",
          "target": "name: `应用标题层级 ${this.headingSize}`"
        },
        {
          "source": "name: `Increase Headings${this.includesNoHeadingsLine ? \"(forced)\" : \"\"}`",
          "target": "name: `增加标题层级${this.includesNoHeadingsLine ? \"(forced)\" : \"\"}`"
        },
        {
          "source": "name: \"Decrease Headings\"",
          "target": "name: \"降低标题层级\""
        },
        {
          "source": "name: `Insert Heading at current level`",
          "target": "name: `在当前层级插入一个新的标题`"
        },
        {
          "source": "name: `Insert Heading at one level deeper`",
          "target": "name: `在当前层级基础上插入低一级的标题`"
        },
        {
          "source": "name: `Insert Heading at one level higher`",
          "target": "name: `在当前层级基础上插入高一级的标题`"
        },
        {
          "source": "text: \"Style to remove\"",
          "target": "text: \"样式移除\""
        },
        {
          "source": "text: \"If this style is at the <position> of a line, remove it\"",
          "target": "text: \"如果该样式位于行内，则将其删除\""
        },
        {
          "source": "text: \"Beginning\"",
          "target": "text: \"开头\""
        },
        {
          "source": "text: \"Surrounding\"",
          "target": "text: \"两侧\""
        },
        {
          "source": ".setName(\"Lower limit of Heading\")",
          "target": ".setName(\"标题层级最低限制\")"
        },
        {
          "source": ".setName(\"Enable override tab behavior\")",
          "target": ".setName(\"启用覆盖标签行为\")"
        },
        {
          "source": ".setName(\"Unordered list\")",
          "target": ".setName(\"无序列表\")"
        },
        {
          "source": ".setName(\"Ordered list\")",
          "target": ".setName(\"有序列表\")"
        },
        {
          "source": ".setName(\"User defined\")",
          "target": ".setName(\"用户定义\")"
        },
        {
          "source": ".setName(\"Bold\")",
          "target": ".setName(\"粗体\")"
        },
        {
          "source": ".setName(\"Italic\")",
          "target": ".setName(\"斜体\")"
        },
        {
          "source": ".setDesc(\"The lower Heading Size that will be decreased by the Heading Shift \")",
          "target": ".setDesc(\"最低标题层级大小\")"
        },
        {
          "source": ".setDesc('Tab execute \"Increase Headings\" and Shift-Tab execute \"Decrease Headings\"')",
          "target": ".setDesc('Tab 键执行“增加标题层级”和Shift-Tab 键执行“减少标题层级”')"
        },
        {
          "source": ".setDesc(\"-\")",
          "target": ".setDesc(\"-\")"
        },
        {
          "source": ".setDesc(\"1., 2. ,3. ,...\")",
          "target": ".setDesc(\"1., 2. ,3. ,...\")"
        },
        {
          "source": ".setDesc(\"Arbitrary string (regular expression)\")",
          "target": ".setDesc(\"任意字符串（正则表达式）\")"
        },
        {
          "source": ".setDesc(\"**|__\")",
          "target": ".setDesc(\"**|__\")"
        },
        {
          "source": ".setDesc(\"*|_\")",
          "target": ".setDesc(\"*|_\")"
        }
      ]
    }
  }
}