        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Save your chat history in a specified folder.",
          "target": "将聊天历史记录保存在指定文件夹中。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Enable model to rename the note title when saving chat history.",
          "target": "启用模型在保存聊天历史记录时重命名笔记标题。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Enable Ollama models to stream response.",
          "target": "启用 Ollama 模型进行流式响应。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Enable Mirostat sampling for controlling perplexity. (default: 0, 0 = disabled, 1 = Mirostat, 2 = Mirostat 2.0)",
          "target": "启用 Mirostat 采样以控制困惑度。（默认值：0，0 = 禁用，1 = Mirostat，2 = Mirostat 2.0）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Influences how quickly the algorithm responds to feedback from the generated text. A lower learning rate will result in slower adjustments, while a higher learning rate will make the algorithm more responsive. (Default: 0.1)",
          "target": "影响算法对生成文本反馈的响应速度。较低的学习率将导致调整较慢，而较高的学习率将使算法更具响应性。（默认值：0.1）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Controls the balance between coherence and diversity of the output. A lower value will result in more focused and coherent text. (Default: 5.0)",
          "target": "控制输出连贯性与多样性之间的平衡。较低的值将产生更集中、更连贯的文本。（默认值：5.0）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Sets the size of the context window used to generate the next token. (Default: 2048)",
          "target": "设置用于生成下一个标记的上下文窗口大小。（默认值：2048）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "The number of GQA groups in the transformer layer. Required for some models, for example it is 8 for llama2:70b.",
          "target": "Transformer 层中的 GQA 组数。某些模型需要此参数，例如 llama2:70b 为 8。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Sets how far back for the model to look back to prevent repetition. (Default: 64, 0 = disabled, -1 = num_ctx)",
          "target": "设置模型为防止重复而回溯的范围。（默认值：64，0 = 禁用，-1 = num_ctx）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Sets how strongly to penalize repetitions. A higher value (e.g., 1.5) will penalize repetitions more strongly, while a lower value (e.g., 0.9) will be more lenient. (Default: 1.1)",
          "target": "设置对重复的惩罚强度。较高的值（例如 1.5）将更强烈地惩罚重复，而较低的值（例如 0.9）将更宽容。（默认值：1.1）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Sets the random number seed to use for generation. Setting this to a specific number will make the model generate the same text for the same prompt.",
          "target": "设置用于生成的随机数种子。将其设置为特定数字将使模型对相同的提示生成相同的文本。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Tail free sampling is used to reduce the impact of less probable tokens from the output. A higher value (e.g., 2.0) will reduce the impact more, while a value of 1.0 disables this setting. (default: 1)",
          "target": "尾部自由采样用于减少输出中概率较低的标记的影响。较高的值（例如 2.0）将减少更多影响，而值为 1.0 则禁用此设置。（默认值：1）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Reduces the probability of generating nonsense. A higher value (e.g. 100) will give more diverse answers, while a lower value (e.g. 10) will be more conservative. (Default: 40)",
          "target": "减少生成无意义内容的概率。较高的值（例如 100）将给出更多样化的答案，而较低的值（例如 10）将更保守。（默认值：40）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Works together with top-k. A higher value (e.g., 0.95) will lead to more diverse text, while a lower value (e.g., 0.5) will generate more focused and conservative text. (Default: 0.9)",
          "target": "与 top-k 协同工作。较高的值（例如 0.95）将产生更多样化的文本，而较低的值（例如 0.5）将生成更集中、更保守的文本。（默认值：0.9）"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Alternative to the top_p, and aims to ensure a balance of quality and variety. The parameter p represents the minimum probability for a token to be considered, relative to the probability of the most likely token. (Default: 0.0)",
          "target": "top_p 的替代方案，旨在确保质量与多样性的平衡。参数 p 表示一个标记被考虑的最小概率，相对于最可能标记的概率。（默认值：0.0）"
        },
        {
