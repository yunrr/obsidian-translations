        },
        {
          "source": ".setDesc(\"Show .canvas files in the recent list\")",
          "target": ".setDesc(\"在最近列表中显示 .canvas 文件\")"
        },
        {
          "source": ".setDesc(\"Show .csv files in the recent list\")",
          "target": ".setDesc(\"在最近列表中显示 .csv 文件\")"
        },
        {
