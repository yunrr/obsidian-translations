          "target": ".setPlaceholder(`文件夹1 文件夹2/子文件夹`)"
        },
        {
          "source": ".setPlaceholder(`folder1/note.md\nfolder2/image.png`)",
          "target": ".setPlaceholder(`文件夹 1/笔记.md 文件夹 2/图片.png`)"
        },
        {
          "source": ".setPlaceholder(\"modified\")",
          "target": ".setPlaceholder(\"填写更改\")"
        },
        {
          "source": ".setTitle(\"Delete\")",
          "target": ".setTitle(\"删除\")"
        },
        {
          "source": ".addOption(\"1\",\"1 line\")",
          "target": ".addOption(\"1\",\"1 行\")"
        },
        {
          "source": ".addOption(\"2\",\"2 lines\")",
          "target": ".addOption(\"2\",\"2 行\")"
        },
        {
          "source": ".addOption(\"3\",\"3 lines\")",
          "target": ".addOption(\"3\",\"3 行\")"
