          "target": "text: `上次同步时间: ${new Date(this.plugin.settings.lastSyncTimestamp).toLocaleString()}`"
        },
        {
          "source": ".setName(\"Api key\")",
          "target": ".setName(\"API密钥\")"
        },
        {
          "source": ".setName(\"Api endpoint\")",
          "target": ".setName(\"Api endpoint\")"
        },
        {
