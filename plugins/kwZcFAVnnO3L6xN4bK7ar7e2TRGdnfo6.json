          "target": ".error(\"读取文件时出错:\", error)"
        },
        {
          "source": ".error(\"Error updating bookmark in Hoarder:\", error)",
          "target": ".error(\"在Hoarder中更新书签时出错:\", error)"
        },
        {
          "source": ".error(\"Error syncing bookmarks:\", error)",
          "target": ".error(\"同步书签时出现错误:\", error)"
