        },
        {
          "source": ".setDesc(\n      \"Download images and other assets locally (if disabled, assets will be embedded using their source URLs)\"\n    )",
          "target": ".setDesc(\n      \"下载图像和其他资源到本地（如果禁用，资源将使用其源URL嵌入）\"\n    )"
        },
        {
          "source": ".setDesc(\"Sync bookmarks now\")",
          "target": ".setDesc(\"立即同步书签\")"
        },
        {
          "source": ".setPlaceholder(\"Enter your API key\")",
          "target": ".setPlaceholder(\"请输入您的API密钥\")"
        },
        {
          "source": ".setPlaceholder(\"Enter API endpoint\")",
          "target": ".setPlaceholder(\"输入 API 终点\")"
        },
        {
          "source": ".setPlaceholder(\"Example: folder1/folder2\")",
          "target": ".setPlaceholder(\"示例: 文件夹1/文件夹2\")"
        },
        {
          "source": ".setPlaceholder(\"Example: folder1/attachments\")",
          "target": ".setPlaceholder(\"示例: 文件夹1/附件\")"
        },
        {
