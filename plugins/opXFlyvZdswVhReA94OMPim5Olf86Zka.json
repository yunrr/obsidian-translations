{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "heatmap-calendar",
    "version": "2.0.0",
    "title": "Heatmap Calendar",
    "description": "Activity Year Overview for DataviewJS, Github style – Track Goals, Progress, Habits, Tasks, Exercise, Finances, \"Dont Break the Chain\" etc.",
    "language": "zh-cn",
    "supportedVersions": "0.7.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(\"settings\", this.plugin.settings)",
          "target": ".log(\"设置\", this.plugin.settings)"
        },
        {
          "source": ".log(\"heyoh\", yield this.loadData()",
          "target": ".log(\"heyoh\", yield this.loadData()"
        },
        {
          "source": "text: \"Colors\"",
          "target": "text: \"颜色\""
        },
        {
          "source": "text: \"Add lists of colors which will be globally available on your heatmaps.\"",
          "target": "text: \"添加全局可用的热图颜色列表。\""
        },
        {
          "source": "text: \"You can use those colors by referencing their name in your heatmap render settings.\"",
          "target": "text: \"您可以在热图渲染设置中通过引用它们的名称来使用这些颜色。\""
        },
        {
          "source": "text: \"Heatmap Calendar Settings\"",
          "target": "text: \"热图日历设置\""
        },
        {
          "source": "text: \"Jan\"",
          "target": "text: \"一月\""
        },
        {
          "source": "text: \"Feb\"",
          "target": "text: \"二月\""
        },
        {
          "source": "text: \"Mar\"",
          "target": "text: \"三月\""
        },
        {
          "source": "text: \"Apr\"",
          "target": "text: \"四月\""
        },
        {
          "source": "text: \"May\"",
          "target": "text: \"五月\""
        },
        {
          "source": "text: \"Jun\"",
          "target": "text: \"六月\""
        },
        {
          "source": "text: \"Jul\"",
          "target": "text: \"七月\""
        },
        {
          "source": "text: \"Aug\"",
          "target": "text: \"八月\""
        },
        {
          "source": "text: \"Sep\"",
          "target": "text: \"九月\""
        },
        {
          "source": "text: \"Oct\"",
          "target": "text: \"十月\""
        },
        {
          "source": "text: \"Nov\"",
          "target": "text: \"十一月\""
        },
        {
          "source": "text: \"Dec\"",
          "target": "text: \"十二月\""
        },
        {
          "source": ".setName(\"Week Start Day\")",
          "target": ".setName(\"周开始日\")"
        },
        {
          "source": ".setDesc(\"Select the day on which your week starts.\")",
          "target": ".setDesc(\"选择你的星期从哪一天开始。\")"
        }
      ]
    }
  }
}