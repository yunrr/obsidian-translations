{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "float-search",
    "version": "2.0.0",
    "title": "Floating Search",
    "description": "You can use search view in modal/leaf/popout window now.",
    "language": "zh-cn",
    "supportedVersions": "4.0.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "name:\"Show/hide file path\"",
          "target": "name:\"显示/隐藏文件路径\""
        },
        {
          "source": "name:\"Search obsidian globally\"",
          "target": "name:\"全局搜索 Obsidian\""
        },
        {
          "source": "name:\"Search Obsidian Globally (With Last State)\"",
          "target": "name:\"全局搜索 Obsidian（保留上次状态）\""
        },
        {
          "source": "name:\"Search in backlink Of current file\"",
          "target": "name:\"在当前文件的反向链接中搜索\""
        },
        {
          "source": "name:\"Search in current file\"",
          "target": "name:\"在当前文件中搜索\""
        },
        {
          "source": "name:`Open search view (${t})`",
          "target": "name:`打开搜索视图 (${t})`"
        },
        {
          "source": ".setName(\"Show file path\")",
          "target": ".setName(\"显示文件路径\")"
        },
        {
          "source": ".setName(\"Show instructions\")",
          "target": ".setName(\"显示说明\")"
        },
        {
          "source": ".setName(\"Default view type\")",
          "target": ".setName(\"默认视图类型\")"
        },
        {
          "source": ".setTooltip(\"Switch to File View\")",
          "target": ".setTooltip(\"切换到文件视图\")"
        },
        {
          "source": ".setTitle(`${l.type} view`)",
          "target": ".setTitle(`${l.type} 视图`)"
        },
        {
          "source": ".setTitle('Search \"'+s+'\" in Float Search')",
          "target": ".setTitle('在浮动搜索中搜索 \"'+s+'\"')"
        },
        {
          "source": ".setTitle(\"Open in Float Preview\")",
          "target": ".setTitle(\"在浮动预览中打开\")"
        }
      ]
    }
  }
}