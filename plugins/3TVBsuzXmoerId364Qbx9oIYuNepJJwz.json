{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-show-file-path",
    "version": "2.0.0",
    "title": "Show Current File Path",
    "description": "Show the full path of the currently open file in the status bar",
    "language": "zh-cn",
    "supportedVersions": "0.5.2",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(\"Path copied to clipboard\")",
          "target": "Notice(\"路径已复制到剪贴板\")"
        },
        {
          "source": "name: 'Vault Root'",
          "target": "name: '文件库根'"
        },
        {
          "source": "name: 'Copy path'",
          "target": "name: '复制路径'"
        },
        {
          "source": "text: 'Settings'",
          "target": "text: '设置'"
        },
        {
          "source": ".setName('Show file name')",
          "target": ".setName('显示文件名')"
        },
        {
          "source": ".setName('Show icons')",
          "target": ".setName('显示icons')"
        },
        {
          "source": ".setName('Copy absolute path')",
          "target": ".setName('复制绝对路径')"
        },
        {
          "source": ".setDesc('Include name of open file in the path')",
          "target": ".setDesc('在路径中包含打开文件的名称')"
        },
        {
          "source": ".setDesc('Show folder and file icons')",
          "target": ".setDesc('显示文件夹和文件图标')"
        },
        {
          "source": ".setDesc('Copy absolute path on clicking status bar')",
          "target": ".setDesc('单击状态栏时复制绝对路径')"
        },
        {
          "source": ".appendText(`📁 `)",
          "target": ".appendText(`📁`)"
        },
        {
          "source": ".appendText(`📄 `)",
          "target": ".appendText(`📄 `)"
        },
        {
          "source": ".appendText(` » `)",
          "target": ".appendText(`»`)"
        }
      ]
    }
  }
}