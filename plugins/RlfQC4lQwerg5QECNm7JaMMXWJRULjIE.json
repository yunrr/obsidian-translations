{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-underline",
    "version": "2.0.0",
    "title": "Underline",
    "description": "Add underline(`<u>xxx</u>`) with shortcut, and `<center>xxx</center>`, `[[#xxx]]`, `[[#^xxx]]`",
    "language": "zh-cn",
    "supportedVersions": "1.3.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(\"selected\")",
          "target": ".log(\"选择\")"
        },
        {
          "source": ".log(\"not selected\")",
          "target": ".log(\"未选择\")"
        },
        {
          "source": "name: \"Toggle underline tag\"",
          "target": "name: \"切换下划线标记\""
        },
        {
          "source": "name: \"Toggle center tag\"",
          "target": "name: \"切换中心标签\""
        },
        {
          "source": "name: \"Toggle a link to heading in the same file\"",
          "target": "name: \"切换指向同一文件中标题的链接\""
        },
        {
          "source": "name: \"Toggle a link to block in the same file\"",
          "target": "name: \"在同一文件中切换要阻止的链接\""
        }
      ]
    }
  }
}