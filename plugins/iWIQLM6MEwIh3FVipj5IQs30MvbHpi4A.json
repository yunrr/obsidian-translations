        {
          "source": "Notice(\"A file with the same name already exists.\")",
          "target": "Notice(\"同名文件已存在。\")"
        },
        {
          "source": "Notice(\"Error converting file to markdown.\")",
          "target": "Notice(\"将文件转换为markdown时出错\")"
        },
        {
          "source": ".log(message)",
          "target": ".log(message)"
        },
        {
