        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Vault-relative path of the note where your grocery list is stored. Edited by the plugin and by you.",
          "target": "存储购物清单的笔记相对于保险库的路径。由插件和您编辑。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Notes whose frontmatter `type` matches this value are treated as recipes. Used for auto-open and the recipe library.",
          "target": "frontmatter `type` 匹配此值的笔记将被视为食谱。用于自动打开和食谱库。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Automatically switch to the recipe card view when you open a note whose `type` matches the value above.",
          "target": "当您打开一个 `type` 匹配上述值的笔记时，自动切换到食谱卡片视图。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "The heading in your recipe notes that introduces the ingredients list (case-insensitive).",
          "target": "食谱笔记中引入食材列表的标题（不区分大小写）。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "The heading in your recipe notes that introduces the cooking steps (case-insensitive).",
          "target": "食谱笔记中引入烹饪步骤的标题（不区分大小写）。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Strip the leading H1 from a recipe note's body if it matches the note title, since the recipe view already shows the title above.",
          "target": "如果食谱笔记正文中的前导 H1 与笔记标题匹配，则将其剥离，因为食谱视图已在上方显示标题。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Strip inline images from a recipe note's body if they match the frontmatter image, since the recipe view already shows it as a hero image.",
          "target": "如果食谱笔记正文中的内联图片与 frontmatter 图片匹配，则将其剥离，因为食谱视图已将其显示为主图。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Frontmatter property name used to store a recipe's star rating (1–5). Shown as interactive stars in the mobile recipe header.",
          "target": "用于存储食谱星级评分（1-5）的 frontmatter 属性名称。在移动端食谱头部显示为交互式星星。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Detect duration phrases in cooking steps (e.g. \"bake for 30 minutes\") and show a clickable timer button.",
          "target": "检测烹饪步骤中的时长短语（例如“烘烤 30 分钟”）并显示可点击的计时器按钮。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Start counting down immediately when a timer button is clicked.",
          "target": "点击计时器按钮时立即开始倒计时。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Show timers in compact mode (time only) instead of the full widget. You can toggle per-timer using the resize button.",
          "target": "以紧凑模式（仅显示时间）显示计时器，而不是完整小部件。您可以使用调整大小按钮切换每个计时器。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "When a step says \"10–15 minutes\", which end of the range to use as the timer default.",
          "target": "当步骤说“10-15 分钟”时，使用范围的哪一端作为计时器默认值。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "How many minutes the ▲/▼ stepper buttons add or subtract.",
          "target": "▲/▼ 步进按钮增加或减少多少分钟。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "When on, categories are sorted A–Z automatically. Turn off to set a custom order.",
          "target": "启用时，类别自动按 A-Z 排序。关闭以设置自定义顺序。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Force specific ingredients into a category, regardless of the dictionary or tags. Match is a case-insensitive substring of the ingredient name.",
          "target": "强制将特定食材归入某个类别，无论字典或标签如何。匹配是食材名称的不区分大小写的子字符串。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Show a button in the recipe view to manually record that you cooked a recipe, updating its last made date and cooked count.",
          "target": "在食谱视图中显示一个按钮，用于手动记录您烹饪了某个食谱，更新其上次制作日期和烹饪次数。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Open a date picker instead of using today's date when marking a recipe as cooked.",
          "target": "标记食谱为已烹饪时，打开日期选择器而不是使用今天的日期。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Write today's date to a recipe's frontmatter when it's added to the meal plan. Powers the 'last made' badge in the recipe view.",
          "target": "当食谱添加到膳食计划时，将今天的日期写入其 frontmatter。为食谱视图中的“上次制作”徽章提供支持。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Frontmatter property name used to store the last made date (YYYY-MM-DD).",
          "target": "用于存储上次制作日期（YYYY-MM-DD）的 frontmatter 属性名称。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "How nutrition values are shown in the recipe view — as per-serving numbers or as totals for the whole recipe.",
          "target": "营养值在食谱视图中的显示方式——按每份显示还是按整个食谱的总量显示。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Whether the nutrition values in your recipe frontmatter are totals for the whole recipe or already per serving.",
          "target": "您食谱 frontmatter 中的营养值是整个食谱的总量还是已经是每份的量。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Frontmatter property name for the calories value.",
          "target": "用于存储卡路里值的 frontmatter 属性名称。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Frontmatter property name for the protein value (grams).",
          "target": "用于存储蛋白质值（克）的 frontmatter 属性名称。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Frontmatter property name for the fat value (grams).",
          "target": "用于存储脂肪值（克）的 frontmatter 属性名称。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Frontmatter property name for the carbs value (grams).",
          "target": "用于存储碳水化合物值（克）的 frontmatter 属性名称。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Recipes cooked within this many days are hidden from the meal suggester to encourage variety. Set to 0 to show all recipes.",
          "target": "在此天数内烹饪过的食谱将从膳食建议器中隐藏，以鼓励多样性。设置为 0 以显示所有食谱。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "How many recipe suggestions to show at once.",
          "target": "一次显示多少个食谱建议。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Frontmatter property that stores a recipe's allergens. Accepts both YAML lists and comma-separated text (e.g. gluten, dairy).",
          "target": "存储食谱过敏原的 frontmatter 属性。接受 YAML 列表和逗号分隔的文本（例如 gluten, dairy）。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Recipes containing any of these allergens show a warning in the recipe view and Shopping Assistant.",
          "target": "包含任何这些过敏原的食谱将在食谱视图和购物助手显示警告。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Show a high-GI badge on ingredients that may cause a rapid blood sugar spike. Informational only — not medical advice.",
          "target": "在可能导致血糖快速飙升的食材上显示高血糖指数徽章。仅供参考——非医疗建议。"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "One regex per line, case-insensitive. Lines starting with # are comments. Matched ingredient names show an up-arrow badge in the recipe view. GI values vary by source — informational only, not medical advice.",
          "target": "每行一个正则表达式，不区分大小写。以 # 开头的行是注释。匹配的食材名称在食谱视图中显示上箭头徽章。血糖指数值因来源而异——仅供参考，非医疗建议。"
        },
