        {
          "source": ".setName(\"Use navigator\")",
          "target": ".setName(\"使用导航器\")"
        },
        {
          "source": ".setName(\"Default mode\")",
          "target": ".setName(\"默认模式\")"
        },
        {
          "source": ".setName(\"Force-directed algorithm\")",
          "target": ".setName(\"力导向算法\")"
        },
        {
          "source": ".setName(\"Global Graph Icon\")",
          "target": ".setName(\"全局关系图图标\")"
        },
        {
          "source": ".setName(\"Automatically add nodes\")",
          "target": ".setName(\"自动添加节点\")"
        },
        {
          "source": ".setName(\"Automatically zoom on active nodes\")",
          "target": ".setName(\"自动缩放至活动节点\")"
        },
        {
          "source": ".setName(\"Zoom speed\")",
          "target": ".setName(\"缩放速度\")"
        },
        {
          "source": ".setName(\"Hover on edges\")",
          "target": ".setName(\"悬停在连线上\")"
        },
        {
          "source": ".setName(\"Open with shift\")",
          "target": ".setName(\"按住 Shift 键打开\")"
        },
        {
          "source": ".setName(\"Typed links prefix\")",
          "target": ".setName(\"类型化链接前缀\")"
        },
        {
          "source": ".setName(\"Render images in graph\")",
          "target": ".setName(\"在关系图中渲染图片\")"
        },
        {
          "source": ".setName(\"Image server port\")",
          "target": ".setName(\"图片服务器端口\")"
        },
        {
          "source": ".setName(\"Debug\")",
          "target": ".setName(\"调试\")"
        },
        {
          "source": ".setDesc(\"Use the navigator overview in the bottom-right corner. Disabling could improve performance.\")",
          "target": ".setDesc(\"在右下角使用导航器概览。禁用可以提升性能。\")"
        },
        {
          "source": ".setDesc(\"The default mode to open the Advanced Graph View in.\")",
          "target": ".setDesc(\"打开高级关系图视图时的默认模式。\")"
        },
        {
          "source": ".setDesc(\"The default force-directed graph drawing algorithm to use. Cola is nice, but unstable in some use cases. Obsidian uses D3\")",
          "target": ".setDesc(\"要使用的默认力导向关系图绘制算法。Cola 效果不错，但在某些用例中不稳定。Obsidian 官方使用的是 D3。\")"
        },
        {
          "source": ".setDesc(\"Show the Global Graph Icon on the left ribbon.\")",
          "target": ".setDesc(\"在左侧功能区显示全局关系图图标。\")"
        },
        {
          "source": ".setDesc(\"This will automatically add nodes to the graph whenever a note is opened.\")",
          "target": ".setDesc(\"打开笔记时，将自动把节点添加到关系图中。\")"
        },
        {
          "source": ".setDesc(\"This will automatically keep fitting the viewport on the currently active node. In particular, this happens when you open a file.\")",
          "target": ".setDesc(\"将自动保持视图聚焦在当前活动的节点上。尤其是在您打开文件时。\")"
        },
        {
          "source": ".setDesc(\"Speed with which zooming in and out happens. A value of 1 is recommended, but can be too quick for some mice.\")",
          "target": ".setDesc(\"控制缩放的速度。推荐值为 1，但对于某些鼠标可能过快。\")"
        },
        {
          "source": ".setDesc(\"Hover on edges to show what they are connected to.\")",
          "target": ".setDesc(\"悬停在连线上以显示其连接的节点。\")"
        },
        {
          "source": ".setDesc(\"Only opens file when clicking on a node when shift is pressed.\")",
          "target": ".setDesc(\"仅在按住 Shift 键并单击节点时才打开文件。\")"
        },
        {
          "source": ".setDesc(\"Prefix to use for typed links. Default is '-'. Requires a server restart.\")",
          "target": ".setDesc(\"用于类型化链接的前缀。默认为 '-'。需要重启服务。\")"
        },
        {
          "source": ".setDesc(\"This will show image attachments in your vault as images in the graph. Requires reloading Juggl. WARNING: On Windows this will trigger your firewall!\")",
          "target": ".setDesc(\"将在关系图中把库中的图片附件显示为图片。需要重载 Juggl。警告：在 Windows 上这会触发防火墙！\")"
        },
        {
          "source": ".setDesc(\"Set the port of the image server. If you use multiple vaults, these need to be set differently. Default 3837.\")",
          "target": ".setDesc(\"设置图片服务器的端口。如果您使用多个库，需要将它们设置为不同的端口。默认为 3837。\")"
        },
        {
          "source": ".setDesc(\"Enable debug mode, which prints a lot of stuff in the developers console.\")",
          "target": ".setDesc(\"启用调试模式，这将在开发者控制台中打印大量信息。\")"
        },
        {
          "source": ".setPlaceholder(\"\").setValue(this.plugin.settings.typedLinkPrefix).onChange((C=>{this.plugin.settings.typedLinkPrefix=C,this.plugin.saveData(this.plugin.settings)}))})),new C.Setting(e).setName(\"Render images in graph\")",
