{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-query-control",
    "version": "2.0.0",
    "title": "obsidian-query-control",
    "description": "An experimental Obsidian plugin that adds additional control to queries",
    "language": "zh-cn",
    "supportedVersions": "0.6.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(o)",
          "target": ".log(o)"
        },
        {
          "source": ".log(R)",
          "target": ".log(R)"
        },
        {
          "source": ".setName(\"Collapse query results by default\")",
          "target": ".setName(\"折叠查询结果\")"
        },
        {
          "source": ".setName(\"Show additional query result context by default\")",
          "target": ".setName(\"显示查询结果的更多上下文\")"
        },
        {
          "source": ".setName(\"Hide query title by default\")",
          "target": ".setName(\"隐藏标题\")"
        },
        {
          "source": ".setName(\"Hide query results by default\")",
          "target": ".setName(\"隐藏查询结果\")"
        },
        {
          "source": ".setName(\"Render results as Markdown by default\")",
          "target": ".setName(\"以Makrdown格式显示结果\")"
        },
        {
          "source": ".setName(\"Default query result sort order\")",
          "target": ".setName(\"默认排序方式\")"
        },
        {
          "source": ".setName(\"Render Markdown\")",
          "target": ".setName(\"渲染Markdown\")"
        }
      ]
    }
  }
}