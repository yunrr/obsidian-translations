{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "copy-image",
    "version": "2.0.0",
    "title": "Copy Image",
    "description": "Easily copy image from Obsidian to clipboard by right clicking image.",
    "language": "zh-cn",
    "supportedVersions": "1.0.8",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(\"Copying the image...\")",
          "target": "Notice(\"正在复制图片...\")"
        },
        {
          "source": "Notice(e.message)",
          "target": "Notice(e.message)"
        },
        {
          "source": "Notice(\"Image copied to clipboard!\")",
          "target": "Notice(\"图片已复制到剪贴板！\")"
        },
        {
          "source": "Notice(\"Failed to copy...\")",
          "target": "Notice(\"复制失败\")"
        }
      ]
    }
  }
}