{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "customizable-menu",
    "version": "2.0.0",
    "title": "Customizable Menu",
    "description": "Allows you to add any command to Obsidian's right-click menu.",
    "language": "zh-cn",
    "supportedVersions": "2.2.0",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setButtonText(\"Add Command\")",
          "target": ".setButtonText(\"添加命令\")"
        },
        {
          "source": ".setName(\"Add command to menu\")",
          "target": ".setName(\"将命令添加到菜单\")"
        },
        {
          "source": ".setDesc(\"Add a new command to the right-click menu\")",
          "target": ".setDesc(\"向右键菜单添加一个新的命令\")"
        },
        {
          "source": ".setDesc(\"Enter the names of the commands as a comma-separated list. Commands are case-sensitive. You will need to restart Obsidian for the changes to take effect.\")",
          "target": ".setDesc(\"输入你需要隐藏的命令，多条命令用逗号隔开。命令区分大小写。你需要重启Obsidian以使更改生效。\")"
        },
        {
          "source": ".setPlaceholder(\"Pick an icon\")",
          "target": ".setPlaceholder(\"选择一个图标\")"
        },
        {
          "source": ".setPlaceholder('Enter commands to hide')",
          "target": ".setPlaceholder('输入要隐藏的命令')"
        },
        {
          "source": ".setTooltip(\"Remove command\")",
          "target": ".setTooltip(\"移除命令\")"
        },
        {
          "source": ".setTooltip(\"Edit icon\")",
          "target": ".setTooltip(\"编辑图标\")"
        },
        {
          "source": ".createEl('h2', { text: 'Add commands' })",
          "target": ".createEl('h2', { text: '添加命令' })"
        },
        {
          "source": ".createEl('h2', { text: 'Hide commands' })",
          "target": ".createEl('h2', { text: '隐藏命令' })"
        }
      ]
    }
  }
}