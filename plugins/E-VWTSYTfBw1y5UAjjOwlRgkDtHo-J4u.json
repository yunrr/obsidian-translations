{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "arweave-uploader",
    "version": "1.0.0",
    "title": "Arweave Uploader",
    "description": "Arweave Uploader Localization & Tweaks",
    "language": "zh-cn",
    "supportedVersions": "1.0.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [
        {
          "type": "AssignmentExpression",
          "name": "textContent",
          "source": "Upload note to Arweave",
          "target": "上传笔记到 Arweave"
        },
        {
          "type": "CallExpression",
          "name": "error",
          "source": "[chunk] This could indicate that the chunk wasn't uploaded or hasn't yet seeded properly to a particular gateway/node",
          "target": "[chunk] 这可能表明该块未上传或尚未正确播种到特定网关/节点"
        },
        {
          "type": "CallExpression",
          "name": "setDesc",
          "source": "Enter your wallet private key here",
          "target": "在此输入您的钱包私钥"
        },
        {
          "type": "CallExpression",
          "name": "setName",
          "source": "Private key",
          "target": "私钥"
        },
        {
          "type": "CallExpression",
          "name": "setPlaceholder",
          "source": "Enter your private key...",
          "target": "输入您的私钥..."
        },
        {
          "type": "CallExpression",
          "name": "warn",
          "source": "Transaction Verification Failed! \n",
          "target": "交易验证失败！"
        },
        {
          "type": "CallExpression",
          "name": "warn",
          "source": "N.B. ArweaveJS is only guaranteed to verify txs created using ArweaveJS.",
          "target": "注意：ArweaveJS 仅保证验证使用 ArweaveJS 创建的交易。"
        },
        {
          "type": "CallExpression",
          "name": "warn",
          "source": "Did you mean to use 'transaction[\"tags\"]' ?",
          "target": "您是否想使用 'transaction[\\\"tags\\\"]'？"
        },
        {
          "type": "NewExpression",
          "name": "Notice",
          "source": "No active note to export",
          "target": "没有活动笔记可导出"
        },
        {
          "type": "NewExpression",
          "name": "Notice",
          "source": "Error sending transaction",
          "target": "发送交易时出错"
        },
        {
          "type": "ObjectProperty",
          "name": "name",
          "source": "Open modal",
          "target": "打开模态框"
        },
        {
          "type": "ObjectProperty",
          "name": "text",
          "source": "Upload note to Arweave",
          "target": "上传笔记到 Arweave"
        },
        {
          "type": "ObjectProperty",
          "name": "text",
          "source": "Tx sent",
          "target": "交易已发送"
        }
      ],
      "regex": []
    }
  }
}