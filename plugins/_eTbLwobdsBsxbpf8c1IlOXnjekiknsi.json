{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-footnotes",
    "version": "2.0.0",
    "title": "Footnote Shortcut",
    "description": "Insert and write footnotes faster",
    "language": "zh-cn",
    "supportedVersions": "0.1.3",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setName(\"Enable Footnote Autosuggest\")",
          "target": ".setName(\"启用脚注自动建议\")"
        },
        {
          "source": ".setName(\"Footnote Section Heading\")",
          "target": ".setName(\"脚注部分标题\")"
        },
        {
          "source": ".setPlaceholder(\"Heading is Empty\")",
          "target": ".setPlaceholder(\"标题为空\")"
        },
        {
          "source": "name: \"Insert / Navigate Auto-Numbered Footnote\"",
          "target": "name: \"插入/导航自动编号脚注\""
        },
        {
          "source": "name: \"Insert / Navigate Named Footnote\"",
          "target": "name: \"插入/导航命名脚注\""
        },
        {
          "source": "text: \"Footnote Shortcut\"",
          "target": "text: \"脚注快捷方式\""
        },
        {
          "source": "text: \"README\"",
          "target": "text: \"说明文档\""
        },
        {
          "source": "text: \"Footnotes Section Behavior\"",
          "target": "text: \"脚注区域行为\""
        },
        {
          "source": ".setName(\"Enable Footnote Section Heading\")",
          "target": ".setName(\"启用脚注标题\")"
        },
        {
          "source": ".setDesc(\"Suggests existing footnotes when entering named footnotes.\")",
          "target": ".setDesc(\"输入命名脚注时建议显示现有脚注。\")"
        },
        {
          "source": ".setDesc(\"Automatically adds a heading separating footnotes at the bottom of the note from the rest of the text.\")",
          "target": ".setDesc(\"自动在笔记底部添加一个标题，将脚注与正文其他部分分隔开。\")"
        },
        {
          "source": ".setDesc(\"Heading to place above footnotes section (Supports Markdown formatting). Heading will be H1 size.\")",
          "target": ".setDesc(\"前往脚注部分上方（支持 Markdown 格式）。标题将为 H1 字号。\")"
        },
        {
          "source": ".appendText('Need help? Check the ')",
          "target": ".appendText(' 需要帮助吗？请查看...')"
        },
        {
          "source": ".appendText('!')",
          "target": ".appendText('!')"
        }
      ]
    }
  }
}