{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "obsidian-better-codeblock",
    "version": "2.0.0",
    "title": "obsidian-better-codeblock",
    "description": "Add title, line number to Obsidian code block",
    "language": "zh-cn",
    "supportedVersions": "1.0.8",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".log(\"Loading Better Code Block Plugin\")",
          "target": ".log(\"加载 Better Code Block 插件\")"
        },
        {
          "source": ".log(\"Unloading Better Code Block Plugin\")",
          "target": ".log(\"卸载 Better Code Block 插件\")"
        },
        {
          "source": ".setName(\"Exclude language list\")",
          "target": ".setName(\"排除语言列表\")"
        },
        {
          "source": ".setName(\"Font color of title\")",
          "target": ".setName(\"标题字体颜色\")"
        },
        {
          "source": ".setName(\"Background color of title\")",
          "target": ".setName(\"标题背景颜色\")"
        },
        {
          "source": ".setName(\"HighLight Color\")",
          "target": ".setName(\"高亮颜色\")"
        },
        {
          "source": ".setName(\"Show line number\")",
          "target": ".setName(\"显示行号\")"
        },
        {
          "source": ".setName(\"Show dividing line\")",
          "target": ".setName(\"显示分割线\")"
        },
        {
          "source": ".setName(\"Show language name in the top right\")",
          "target": ".setName(\"在右上角显示语言名称\")"
        },
        {
          "source": ".setDesc(\"Title and line numbers do not apply in these languages, separate by `,`\")",
          "target": ".setDesc(\"标题和行号在这些语言中不适用，请用`,`分开。\")"
        },
        {
          "source": ".setPlaceholder(\"like todoist,other,...\")",
          "target": ".setPlaceholder(\"像 Todoist，其他...\")"
        },
        {
          "source": ".setPlaceholder(\"Enter a color\")",
          "target": ".setPlaceholder(\"输入一个颜色\")"
        }
      ]
    }
  }
}