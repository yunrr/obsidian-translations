{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "explorer-colors",
    "version": "2.0.0",
    "title": "Explorer Colors",
    "description": "Set custom colors for files and folders.",
    "language": "zh-cn",
    "supportedVersions": "1.0.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": "Notice(this.itemType+\" color changed\")",
          "target": "Notice(this.itemType+\" 颜色变了\")"
        },
        {
          "source": "text:\"Select a color for this \"",
          "target": "text:\"为此选择一种颜色 \""
        },
        {
          "source": ".setText(\"Change color\")",
          "target": ".setText(\"更改颜色\")"
        },
        {
          "source": ".setButtonText(\"Reset\")",
          "target": ".setButtonText(\"重置\")"
        },
        {
          "source": ".setButtonText(\"Save\")",
          "target": ".setButtonText(\"保存\")"
        }
      ]
    }
  }
}