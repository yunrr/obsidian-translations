{
  "schemaVersion": 1,
  "metadata": {
    "plugin": "vault-name-status-bar",
    "version": "2.0.0",
    "title": "vault-name-status-bar",
    "description": "Vault name in status bar. can be reduced to ::",
    "language": "zh-cn",
    "supportedVersions": "1.1.1",
    "author": ""
  },
  "dict": {
    "main.js": {
      "ast": [],
      "regex": [
        {
          "source": ".setName(\"Reduced at Start\")",
          "target": ".setName(\"启动时收起\")"
        },
        {
          "source": ".setName(\"Set color & size\")",
          "target": ".setName(\"设置字体颜色和大小\")"
        },
        {
          "source": ".setDesc(\"Will be reduced by default\")",
          "target": ".setDesc(\"默认情况下会收起\")"
        },
        {
          "source": ".createEl(\"h2\", { text: \"Vaut Name in Status Bar\" })",
          "target": ".createEl(\"h2\", { text:\"状态栏显示库名\" })"
        },
        {
          "source": ".createEl(\"p\", { text: \"Click on the vault name or on :: to reduce or enlarge\" })",
          "target": ".createEl(\"p\", {text:\"点击库名称或：：以收起或显示\" })"
        }
      ]
    }
  }
}